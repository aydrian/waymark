{
  "name": "@itsaydrian/waymark-shared",
  "version": "0.0.1",
  "description": "Shared types and utilities for Waymark travel itinerary platform",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types/index.js",
    "./lib": "./dist/lib/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "waymark",
    "travel",
    "itinerary",
    "types",
    "zod"
  ],
  "author": "Aydrian Howard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aydrian/waymark.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/aydrian/waymark/issues"
  },
  "homepage": "https://github.com/aydrian/waymark/tree/main/packages/shared#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.8.3"
  }
}
