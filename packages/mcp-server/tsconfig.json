{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@itsaydrian/waymark-shared": ["../shared/src/index.ts"],
      "@itsaydrian/waymark-shared/types": ["../shared/src/types/index.ts"],
      "@itsaydrian/waymark-shared/lib": ["../shared/src/lib/index.ts"]
    },
    "lib": ["ES2022", "DOM"],
    "types": ["@cloudflare/workers-types", "bun"],
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../shared" }
  ]
}
