{
  "name": "@itsaydrian/waymark-mcp-server",
  "version": "0.1.7",
  "description": "Model Context Protocol server for Waymark travel itinerary management",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./server": "./dist/src/server.js"
  },
  "bin": {
    "waymark-mcp": "dist/src/transports/stdio.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev:stdio": "bun src/transports/stdio.ts",
    "dev:http": "bun src/transports/http.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "waymark",
    "travel",
    "itinerary",
    "claude"
  ],
  "author": "Aydrian Howard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aydrian/waymark.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/aydrian/waymark/issues"
  },
  "homepage": "https://github.com/aydrian/waymark/tree/main/packages/mcp-server#readme",
  "dependencies": {
    "@itsaydrian/waymark-shared": "^0.0.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
