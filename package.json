{
  "name": "@waymark/root",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @waymark/web dev",
    "build": "bun run --filter @waymark/web build",
    "preview": "bun run --filter @waymark/web preview",
    "deploy": "bun run --filter @waymark/web deploy",
    "test": "bun test",
    "sync:kv": "bun run --filter @waymark/web sync:kv"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@codemirror/lang-json": "^6.0.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "astro": "^6.1.8",
    "codemirror": "^6.0.2",
    "leaflet": "^1.9.4",
    "lucide-astro": "^0.556.0",
    "svix": "^1.90.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.6.0",
    "resend": "^6.12.0",
    "tailwindcss": "^4.2.2",
    "wrangler": "^4.83.0"
  }
}
