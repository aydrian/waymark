{
  "name": "@waymark/root",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "bun run --filter @waymark/web dev",
    "web:build": "bun run --filter @waymark/web build",
    "web:preview": "bun run --filter @waymark/web preview",
    "web:deploy": "bun run --filter @waymark/web deploy",
    "mcp:dev:stdio": "bun run --filter @itsaydrian/waymark-mcp-server dev:stdio",
    "mcp:dev:http": "bun run --filter @itsaydrian/waymark-mcp-server dev:http"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.8.3"
  }
}
