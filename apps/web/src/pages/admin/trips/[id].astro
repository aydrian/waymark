---
import { env } from 'cloudflare:workers';
import { requireAdminSession } from '../../../lib/admin-auth.js';
import { getTrip, getGlobalPOI, listGlobalPOIs } from '@itsaydrian/waymark-shared/lib';
import TripLayout from '../../../layouts/TripLayout.astro';
import AdminNavbar from '../../../components/AdminNavbar.astro';

const redirect = await requireAdminSession(Astro.request, env.COOKIE_SIGNING_SECRET);
if (redirect) return redirect;

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/trips');

const trip = await getTrip(env.TRIPS, id);
if (!trip) {
  return new Response('Trip not found', { status: 404 });
}

// Load global POIs for this trip's references
const poiReferences = trip.poiReferences ?? [];
const globalPOIs = await Promise.all(
  poiReferences.map(async (ref) => {
    const poi = await getGlobalPOI(env.TRIPS, ref.poiId);
    return poi ? { ...poi, tripAdvisorNotes: ref.tripAdvisorNotes, addedAt: ref.addedAt } : null;
  })
);
const tripPOIs = globalPOIs.filter((p): p is NonNullable<typeof p> => p !== null);

// Also include legacy POIs for backward compatibility
const legacyPOIs = trip.pois ?? [];
const allPOIs = [...tripPOIs, ...legacyPOIs];

// Load all global POIs for the itinerary editor's POI search
const allGlobalPOIs = await listGlobalPOIs(env.TRIPS);

const complexData = {
  stays: trip.stays ?? [],
  transportLegs: trip.transportLegs ?? [],
  rentalCars: trip.rentalCars ?? [],
  map: trip.map ?? null,
  notes: trip.notes ?? null,
};
---
<TripLayout title={`Admin — ${trip.title}`}>
  <AdminNavbar currentPage="edit" />
  <main class="max-w-2xl mx-auto px-4 py-10">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/trips" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]">
        ← Back to Trips
      </a>
      <h1 class="text-xl font-bold">{trip.title}</h1>
      <span class="font-mono text-xs text-[var(--color-text-secondary)]">{trip.id}</span>
    </div>

    <!-- Tabs -->
    <div class="flex border-b border-[var(--color-border)] mb-6">
      <button id="tab-info" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-blue-500 text-blue-400 min-h-[44px]">Info</button>
      <button id="tab-hotels" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] min-h-[44px]">Hotels</button>
      <button id="tab-transport" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] min-h-[44px]">Transport</button>
      <button id="tab-rental" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] min-h-[44px]">Rental Cars</button>
      <button id="tab-itinerary" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] min-h-[44px]">Itinerary ({trip.days.length} days)</button>
      <button id="tab-pois" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] min-h-[44px]">POIs ({allPOIs.length})</button>
      <button id="tab-raw" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-[var(--color-text-secondary)] min-h-[44px]">Raw JSON</button>
    </div>

    <!-- Info Tab -->
    <div id="panel-info">
      <form id="info-form" class="flex flex-col gap-4">
        <input type="hidden" name="id" value={trip.id} />
        <input type="hidden" name="pinSalt" value={trip.pinSalt} />
        <input type="hidden" name="pinHash" value={trip.pinHash} />
        <input type="hidden" name="updatedAt" value={new Date().toISOString()} />

        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Title</label>
          <input name="title" value={trip.title} required
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Start Date</label>
            <input name="startDate" type="date" value={trip.startDate} required
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">End Date</label>
            <input name="endDate" type="date" value={trip.endDate} required
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Timezone</label>
            <input name="timezone" value={trip.timezone} required placeholder="America/New_York"
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Destinations (comma-separated)</label>
            <input name="destinations" value={trip.destinations.join(', ')} required
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Travelers (optional, comma-separated)</label>
            <input name="travelers" value={(trip.travelers ?? []).join(', ')}
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Summary (optional)</label>
          <textarea name="summary" rows="2"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 resize-none"
          >{trip.summary ?? ''}</textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Status</label>
            <select name="status"
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500">
              <option value="planning" selected={trip.status === 'planning'}>Planning</option>
              <option value="booking" selected={trip.status === 'booking'}>Booking</option>
              <option value="travel_ready" selected={trip.status === 'travel_ready'}>Travel Ready</option>
              <option value="traveling" selected={trip.status === 'traveling'}>Traveling</option>
              <option value="post_trip" selected={trip.status === 'post_trip'}>Post Trip</option>
              <option value="completed" selected={trip.status === 'completed'}>Completed</option>
              <option value="closed_lost" selected={trip.status === 'closed_lost'}>Closed — Lost</option>
            </select>
            <input type="hidden" name="originalStatus" value={trip.status} />
          </div>
          <div class="col-span-2">
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Status Reason (optional)</label>
            <input name="statusReason" value={trip.statusReason ?? ''} placeholder="e.g., Pregnancy complications"
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">
            New PIN (leave blank to keep existing)
          </label>
          <input name="pin" type="password" placeholder="••••••"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
        </div>

        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Notes (optional)</label>
          <textarea name="notes" rows="3"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 resize-none"
          >{complexData.notes ?? ''}</textarea>
        </div>
        <input type="hidden" name="mapConfig" id="map-config" value={JSON.stringify(complexData.map ?? null)} />

        <div class="flex items-center justify-between pt-2">
          <button type="submit"
            class="px-5 py-2 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 text-white text-sm font-medium rounded-lg transition-colors min-h-[44px]">
            Save changes
          </button>
          <button type="button" id="delete-btn"
            class="text-sm text-red-400 hover:text-red-300 transition-colors min-h-[44px]">
            Delete trip…
          </button>
        </div>
      </form>
      <p id="info-status" class="text-sm mt-3 hidden"></p>
    </div>

    <!-- Hotels Tab -->
    <div id="panel-hotels" class="hidden"></div>

    <!-- Transport Tab -->
    <div id="panel-transport" class="hidden"></div>

    <!-- Rental Cars Tab -->
    <div id="panel-rental" class="hidden"></div>

    <!-- Itinerary Tab -->
    <div id="panel-itinerary" class="hidden">
      <div id="itinerary-editor"></div>
    </div>

    <!-- POIs Tab -->
    <div id="panel-pois" class="hidden">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-wide">Trip Places of Interest</h2>
        <a href="/admin/pois" class="text-sm text-blue-400 hover:text-blue-300">Manage Global POIs →</a>
      </div>

      {allPOIs.length === 0 ? (
        <p class="text-[var(--color-text-muted)] mb-4">No POIs added to this trip yet.</p>
      ) : (
        <div id="trip-poi-list" class="space-y-3 mb-6">
          {allPOIs.map(poi => (
            <div
              class="poi-item p-4 border border-[var(--color-border)] rounded-lg bg-[var(--color-surface)]"
              data-poi-id={poi.id}
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-medium text-[var(--color-text-primary)]">{poi.name}</h3>
                    <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-secondary)] capitalize">
                      {poi.category}
                    </span>
                    <span class="text-[10px] px-1.5 py-0.5 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-secondary)]">
                      {poi.city}
                    </span>
                  </div>
                  {poi.address && <p class="text-xs text-[var(--color-text-secondary)]">{poi.address}</p>}
                  {poi.advisorNotes && (
                    <p class="text-xs text-amber-500 mt-1 italic">Global: {poi.advisorNotes}</p>
                  )}
                </div>
                <div class="flex flex-col gap-2">
                  <button
                    type="button"
                    class="edit-trip-poi-btn text-xs text-blue-400 hover:text-blue-300 px-3 py-2 rounded hover:bg-blue-500/10 transition-colors min-h-[44px]"
                    data-poi-id={poi.id}
                    data-trip-notes={poi.tripAdvisorNotes || ''}
                  >
                    Edit Trip Notes
                  </button>
                  <button
                    type="button"
                    class="remove-trip-poi-btn text-xs text-red-400 hover:text-red-300 px-3 py-2 rounded hover:bg-red-500/10 transition-colors min-h-[44px]"
                    data-poi-id={poi.id}
                  >
                    Remove from Trip
                  </button>
                </div>
              </div>
              {poi.tripAdvisorNotes && (
                <div class="mt-2 p-2 bg-amber-500/10 rounded">
                  <p class="text-xs text-amber-500">Trip Notes: {poi.tripAdvisorNotes}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      )}

      <div class="border-t border-[var(--color-border)] pt-4">
        <h3 class="text-sm font-medium mb-2">Add Global POI to Trip</h3>
        <p class="text-xs text-[var(--color-text-muted)] mb-2">
          Enter a Global POI ID to add it to this trip. Find POIs in the <a href="/admin/pois" class="text-blue-400 hover:text-blue-300">Global POI Manager</a>.
        </p>
        <form id="add-poi-to-trip-form" class="flex gap-2">
          <input
            name="poiId"
            placeholder="POI ID (e.g., abc-123...)"
            required
            class="flex-1 px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500"
          />
          <button
            type="submit"
            class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors min-h-[44px]"
          >
            Add to Trip
          </button>
        </form>
        <p id="add-poi-status" class="text-sm mt-2 hidden"></p>
      </div>
    </div>

    <!-- Raw JSON Tab -->
    <div id="panel-raw" class="hidden">
      <div id="raw-desktop-warning" class="text-xs text-amber-500 bg-amber-500/10 px-3 py-2 rounded-lg mb-3">
        📱 Best viewed on desktop — the JSON editor is not optimized for mobile screens.
      </div>
      <script>
        if (window.innerWidth >= 768) document.getElementById('raw-desktop-warning')?.classList.add('hidden');
      </script>
      <div id="raw-editor" class="rounded-lg border border-[var(--color-border)] overflow-hidden" style="height:500px; min-height:60dvh"></div>
      <div class="flex items-center gap-3 mt-4">
        <button id="raw-save-btn"
          class="px-5 py-2 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 text-white text-sm font-medium rounded-lg transition-colors min-h-[44px]">
          Save JSON
        </button>
        <p id="raw-status" class="text-sm hidden"></p>
      </div>
    </div>
  </main>

  <!-- Pass server data to client via data attributes (define:vars disables ES module bundling) -->
  <div
    id="trip-data"
    data-complex={JSON.stringify(complexData)}
    data-trip-json={JSON.stringify(trip, null, 2)}
    data-trip-id={trip.id}
    data-trip-start-date={trip.startDate}
    data-itinerary-days={JSON.stringify(trip.days ?? [])}
    data-itinerary-poi-references={JSON.stringify(trip.poiReferences ?? [])}
    data-itinerary-pois={JSON.stringify(trip.pois ?? [])}
    data-all-pois={JSON.stringify(allGlobalPOIs)}
    class="hidden"
  ></div>

  <script>
    import { EditorView, basicSetup } from 'codemirror';
    import { json } from '@codemirror/lang-json';

    const dataEl = document.getElementById('trip-data')!;
    const complexData = JSON.parse(dataEl.dataset.complex!);
    const tripJson = dataEl.dataset.tripJson!;

    const logisticsState = {
      stays: complexData.stays || [],
      transportLegs: complexData.transportLegs || [],
      rentalCars: complexData.rentalCars || [],
    };
    const tripId = dataEl.dataset.tripId!;
    const tripStartDate = dataEl.dataset.tripStartDate!;

    // --- Tab switching ---
    const tabInfo = document.getElementById('tab-info')!;
    const tabHotels = document.getElementById('tab-hotels')!;
    const tabTransport = document.getElementById('tab-transport')!;
    const tabRental = document.getElementById('tab-rental')!;
    const tabItinerary = document.getElementById('tab-itinerary')!;
    const tabPois = document.getElementById('tab-pois')!;
    const tabRaw = document.getElementById('tab-raw')!;
    const panelInfo = document.getElementById('panel-info')!;
    const panelHotels = document.getElementById('panel-hotels')!;
    const panelTransport = document.getElementById('panel-transport')!;
    const panelRental = document.getElementById('panel-rental')!;
    const panelItinerary = document.getElementById('panel-itinerary')!;
    const panelPois = document.getElementById('panel-pois')!;
    const panelRaw = document.getElementById('panel-raw')!;

    function activateTab(which: string) {
      const tabs = [
        { btn: tabInfo, panel: panelInfo, name: 'info' },
        { btn: tabHotels, panel: panelHotels, name: 'hotels' },
        { btn: tabTransport, panel: panelTransport, name: 'transport' },
        { btn: tabRental, panel: panelRental, name: 'rental' },
        { btn: tabItinerary, panel: panelItinerary, name: 'itinerary' },
        { btn: tabPois, panel: panelPois, name: 'pois' },
        { btn: tabRaw, panel: panelRaw, name: 'raw' },
      ];

      tabs.forEach(({ btn, panel, name }) => {
        const isActive = name === which;
        btn.classList.toggle('border-blue-500', isActive);
        btn.classList.toggle('text-blue-400', isActive);
        btn.classList.toggle('border-transparent', !isActive);
        btn.classList.toggle('text-[var(--color-text-secondary)]', !isActive);
        panel.classList.toggle('hidden', !isActive);
      });

      const url = new URL(window.location.href);
      if (which === 'info') url.searchParams.delete('tab');
      else url.searchParams.set('tab', which);
      history.replaceState(null, '', url.toString());
    }

    tabInfo.addEventListener('click', () => activateTab('info'));
    tabHotels.addEventListener('click', () => activateTab('hotels'));
    tabTransport.addEventListener('click', () => activateTab('transport'));
    tabRental.addEventListener('click', () => activateTab('rental'));
    tabItinerary.addEventListener('click', () => activateTab('itinerary'));
    tabPois.addEventListener('click', () => activateTab('pois'));
    tabRaw.addEventListener('click', () => activateTab('raw'));

    // Read ?tab= from URL on load
    const tabParam = new URL(window.location.href).searchParams.get('tab');
    const validTabs = ['info', 'hotels', 'transport', 'rental', 'itinerary', 'pois', 'raw'];
    if (tabParam && validTabs.includes(tabParam)) {
      activateTab(tabParam);
    }

    // --- CodeMirror editors ---
    const scrollTheme = EditorView.theme({ "&": { height: "100%" }, ".cm-scroller": { overflow: "auto" } });

    const rawEditor = new EditorView({
      doc: tripJson,
      extensions: [basicSetup, json(), scrollTheme],
      parent: document.getElementById('raw-editor')!,
    });

    // --- Helpers ---
    function formatIssues(issues: Array<{ path: (string | number)[]; message: string }>): string {
      if (!issues.length) return 'Validation failed';
      const parts = issues.map(i => {
        const path = i.path.reduce<string>((acc, p, idx) =>
          typeof p === 'number' ? `${acc}[${p}]` : idx === 0 ? String(p) : `${acc}.${p}`, '');
        return path ? `${path}: ${i.message}` : i.message;
      });
      return `Validation failed — ${parts.join('; ')}`;
    }

    // --- Info form save ---
    async function saveTrip(payload: unknown) {
      const res = await fetch('/api/admin/trips/upsert', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        credentials: 'same-origin',
      });
      return res.json();
    }

    const infoForm = document.getElementById('info-form') as HTMLFormElement;
    const infoStatus = document.getElementById('info-status')!;

    infoForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(infoForm);
      const submitBtn = infoForm.querySelector('button[type=submit]') as HTMLButtonElement;
      submitBtn.disabled = true;

      const pin = fd.get('pin') as string;
      let mapConfig: unknown = null;
      try { mapConfig = JSON.parse(fd.get('mapConfig') as string); } catch { /* leave null */ }
      const notes = (fd.get('notes') as string).trim() || undefined;

      const payload = {
        id: fd.get('id'),
        title: fd.get('title'),
        startDate: fd.get('startDate'),
        endDate: fd.get('endDate'),
        timezone: fd.get('timezone'),
        destinations: (fd.get('destinations') as string).split(',').map(s => s.trim()).filter(Boolean),
        travelers: fd.get('travelers') ? (fd.get('travelers') as string).split(',').map(s => s.trim()).filter(Boolean) : [],
        summary: fd.get('summary') || undefined,
        status: fd.get('status'),
        statusReason: fd.get('statusReason') || undefined,
        pinSalt: fd.get('pinSalt'),
        pinHash: fd.get('pinHash'),
        updatedAt: new Date().toISOString(),
        stays: logisticsState.stays,
        transportLegs: logisticsState.transportLegs,
        rentalCars: logisticsState.rentalCars,
        map: mapConfig,
        notes,
        days: itineraryState.days,
        poiReferences: itineraryState.poiReferences,
        pois: itineraryState.pois,
        ...(pin ? { pin } : {}),
      };

      try {
        const data = await saveTrip(payload) as { ok?: boolean; error?: string; issues?: Array<{ path: (string | number)[]; message: string }> };
        if (data.ok) {
          infoStatus.textContent = 'Saved.';
          infoStatus.className = 'text-sm mt-3 text-green-400';
        } else {
          infoStatus.textContent = data.issues ? formatIssues(data.issues) : (data.error ?? 'Save failed');
          infoStatus.className = 'text-sm mt-3 text-red-400';
        }
      } catch {
        infoStatus.textContent = 'Network error';
        infoStatus.className = 'text-sm mt-3 text-red-400';
      }
      infoStatus.classList.remove('hidden');
      submitBtn.disabled = false;
    });

    // --- Raw JSON save ---
    const rawSaveBtn = document.getElementById('raw-save-btn') as HTMLButtonElement;
    const rawStatus = document.getElementById('raw-status')!;

    rawSaveBtn.addEventListener('click', async () => {
      rawSaveBtn.disabled = true;
      let parsed;
      try {
        parsed = JSON.parse(rawEditor.state.doc.toString());
      } catch {
        rawStatus.textContent = 'Invalid JSON — fix syntax errors before saving.';
        rawStatus.className = 'text-sm text-red-400';
        rawStatus.classList.remove('hidden');
        rawSaveBtn.disabled = false;
        return;
      }
      try {
        const data = await saveTrip(parsed) as { ok?: boolean; error?: string; issues?: Array<{ path: (string | number)[]; message: string }> };
        if (data.ok) {
          rawStatus.textContent = 'Saved.';
          rawStatus.className = 'text-sm text-green-400';
          logisticsState.stays = parsed.stays ?? [];
          logisticsState.transportLegs = parsed.transportLegs ?? [];
          logisticsState.rentalCars = parsed.rentalCars ?? [];
          const mapConfigEl = document.getElementById('map-config') as HTMLInputElement;
          if (mapConfigEl) mapConfigEl.value = JSON.stringify(parsed.map ?? null);
          const notesEl = document.querySelector<HTMLTextAreaElement>('[name="notes"]');
          if (notesEl) notesEl.value = parsed.notes ?? '';
        } else {
          rawStatus.textContent = data.issues ? formatIssues(data.issues) : (data.error ?? 'Save failed');
          rawStatus.className = 'text-sm text-red-400';
        }
      } catch {
        rawStatus.textContent = 'Network error';
        rawStatus.className = 'text-sm text-red-400';
      }
      rawStatus.classList.remove('hidden');
      rawSaveBtn.disabled = false;
    });

    // --- POIs Tab ---
    // Add POI to trip
    const addPoiForm = document.getElementById('add-poi-to-trip-form') as HTMLFormElement;
    const addPoiStatus = document.getElementById('add-poi-status');

    addPoiForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = addPoiForm.querySelector('button[type=submit]') as HTMLButtonElement;
      submitBtn.disabled = true;
      addPoiStatus?.classList.add('hidden');

      const formData = new FormData(addPoiForm);
      const poiId = formData.get('poiId') as string;

      try {
        const res = await fetch(`/api/admin/trips/${tripId}/pois`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ poiId }),
        });
        const data = await res.json();

        if (res.ok) {
          addPoiStatus.textContent = 'Added! Reloading...';
          addPoiStatus.className = 'text-sm text-green-400 mt-2';
          addPoiStatus.classList.remove('hidden');
          window.location.reload();
        } else {
          addPoiStatus.textContent = data.error || 'Failed to add POI';
          addPoiStatus.className = 'text-sm text-red-400 mt-2';
          addPoiStatus.classList.remove('hidden');
          submitBtn.disabled = false;
        }
      } catch {
        addPoiStatus.textContent = 'Network error';
        addPoiStatus.className = 'text-sm text-red-400 mt-2';
        addPoiStatus.classList.remove('hidden');
        submitBtn.disabled = false;
      }
    });

    // Edit trip notes
    document.querySelectorAll('.edit-trip-poi-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const poiId = btn.getAttribute('data-poi-id');
        const currentNotes = btn.getAttribute('data-trip-notes');
        const newNotes = prompt('Trip-specific notes (visible to this client):', currentNotes || '');

        if (newNotes === null) return; // Cancelled

        try {
          const res = await fetch(`/api/admin/trips/${tripId}/pois/${poiId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tripAdvisorNotes: newNotes }),
          });

          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(data.error || 'Failed to update notes');
          }
        } catch {
          alert('Network error');
        }
      });
    });

    // Remove POI from trip
    document.querySelectorAll('.remove-trip-poi-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const poiId = btn.getAttribute('data-poi-id');
        if (!confirm('Remove this POI from the trip?')) return;

        btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/trips/${tripId}/pois/${poiId}`, {
            method: 'DELETE',
          });

          if (res.ok) {
            (btn.closest('.poi-item') as HTMLElement)?.remove();
          } else {
            const data = await res.json();
            alert(data.error || 'Failed to remove POI');
          }
        } catch {
          alert('Network error');
        }
        btn.disabled = false;
      });
    });

    // --- Itinerary Editor ---
    const itineraryState = {
      days: JSON.parse(dataEl.dataset.itineraryDays!) as any[],
      poiReferences: JSON.parse(dataEl.dataset.itineraryPoiReferences!) as any[],
      pois: JSON.parse(dataEl.dataset.itineraryPois!) as any[],
      allGlobalPOIs: JSON.parse(dataEl.dataset.allPois!) as any[],
    };

    const manuallyReordered: Record<number, boolean> = {};

    const ITEM_TYPE_EMOJI: Record<string, string> = {
      hotel: '🏨', transport: '🚗', activity: '🎯', restaurant: '🍽️', note: '📝', transfer: '🚕',
    };
    const ITEM_STATUS_COLOR: Record<string, string> = {
      booked: 'text-green-400 bg-green-400/10',
      quoted: 'text-yellow-400 bg-yellow-400/10',
      pending: 'text-[var(--color-text-muted)] bg-[var(--color-bg-subtle)]',
      canceled: 'text-red-400 bg-red-400/10',
    };

    function formatDate(dateStr: string): string {
      const d = new Date(dateStr + 'T12:00:00');
      return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
    }

    function generateId(): string {
      return Math.random().toString(36).slice(2, 10);
    }

    function addDay() {
      const days = itineraryState.days;
      let nextDate = tripStartDate;
      if (days.length > 0) {
        const lastDate = new Date(days[days.length - 1].date + 'T12:00:00');
        lastDate.setDate(lastDate.getDate() + 1);
        nextDate = lastDate.toISOString().slice(0, 10);
      }
      const n = days.length + 1;
      days.push({ dayNumber: n, date: nextDate, title: `Day ${n}`, items: [] });
      renderItinerary();
    }

    function removeDay(idx: number) {
      if (!confirm(`Delete Day ${idx + 1}? This cannot be undone.`)) return;
      itineraryState.days.splice(idx, 1);
      itineraryState.days.forEach((d, i) => { d.dayNumber = i + 1; });
      renderItinerary();
    }

    function moveDay(idx: number, dir: -1 | 1) {
      const days = itineraryState.days;
      const target = idx + dir;
      if (target < 0 || target >= days.length) return;
      [days[idx], days[target]] = [days[target], days[idx]];
      days.forEach((d, i) => { d.dayNumber = i + 1; });
      renderItinerary();
    }

    function moveItem(dayIdx: number, itemIdx: number, dir: -1 | 1) {
      const items = itineraryState.days[dayIdx].items;
      const target = itemIdx + dir;
      if (target < 0 || target >= items.length) return;
      [items[itemIdx], items[target]] = [items[target], items[itemIdx]];
      manuallyReordered[dayIdx] = true;
      renderItinerary();
    }

    function removeItem(dayIdx: number, itemIdx: number) {
      if (!confirm('Delete this item?')) return;
      itineraryState.days[dayIdx].items.splice(itemIdx, 1);
      renderItinerary();
    }

    // Modal for adding/editing items
    function openItemModal(dayIdx: number, itemIdx: number | null) {
      const existing = itemIdx !== null ? itineraryState.days[dayIdx].items[itemIdx] : null;
      const overlay = document.createElement('div');
      overlay.className = 'fixed inset-0 bg-black/60 z-50 flex items-start justify-center pt-8 px-4 overflow-y-auto';

      const modal = document.createElement('div');
      modal.className = 'bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-5 w-full max-w-lg mb-8';

      const fields = [
        { key: 'type', label: 'Type', kind: 'select', options: ['hotel','transport','activity','restaurant','transfer','note'], def: 'activity' },
        { key: 'title', label: 'Title', kind: 'text', req: true, def: '' },
        { key: 'status', label: 'Status', kind: 'select', options: ['booked','quoted','pending','canceled'], def: 'pending' },
        { key: 'startTime', label: 'Start Time', kind: 'time', def: '' },
        { key: 'endTime', label: 'End Time', kind: 'time', def: '' },
        { key: 'location', label: 'Location', kind: 'text', def: '' },
        { key: 'address', label: 'Address', kind: 'text', def: '' },
        { key: 'vendor', label: 'Vendor', kind: 'text', def: '' },
        { key: 'confirmationNumber', label: 'Confirmation #', kind: 'text', def: '' },
        { key: 'cost', label: 'Cost', kind: 'number', def: '' },
        { key: 'costCurrency', label: 'Currency', kind: 'select', options: ['USD','EUR','JPY','GBP','CAD','AUD'], def: 'USD' },
        { key: 'notes', label: 'Notes', kind: 'textarea', def: '' },
      ] as const;

      modal.innerHTML = `
        <h3 class="text-sm font-semibold mb-4">${existing ? 'Edit Item' : 'Add Item'}</h3>
        <div class="flex flex-col gap-3">
          ${(fields as any[]).map(f => {
            const val = existing ? ((existing as any)[f.key] ?? f.def) : f.def;
            if (f.kind === 'select') {
              return `<div>
                <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">${f.label}</label>
                <select name="${f.key}" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 min-h-[44px]">
                  ${(f as any).options.map((o: string) => `<option value="${o}"${val === o ? ' selected' : ''}>${o}</option>`).join('')}
                </select>
              </div>`;
            }
            if (f.kind === 'textarea') {
              return `<div>
                <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">${f.label}</label>
                <textarea name="${f.key}" rows="3" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 resize-none">${val}</textarea>
              </div>`;
            }
            return `<div>
              <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">${f.label}</label>
              <input name="${f.key}" type="${f.kind}" value="${val}" ${(f as any).req ? 'required' : ''} class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 min-h-[44px]" />
            </div>`;
          }).join('')}
        </div>
        <div class="flex gap-3 mt-5">
          <button type="button" id="modal-save" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg min-h-[44px]">Save</button>
          <button type="button" id="modal-cancel" class="px-4 py-2 border border-[var(--color-border)] text-sm rounded-lg min-h-[44px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]">Cancel</button>
        </div>
      `;

      overlay.appendChild(modal);
      document.body.appendChild(overlay);

      overlay.addEventListener('click', (e) => { if (e.target === overlay) document.body.removeChild(overlay); });
      modal.querySelector('#modal-cancel')!.addEventListener('click', () => document.body.removeChild(overlay));

      modal.querySelector('#modal-save')!.addEventListener('click', () => {
        const titleInput = modal.querySelector<HTMLInputElement>('[name="title"]')!;
        if (!titleInput.value.trim()) { titleInput.focus(); return; }

        const item: any = { id: existing?.id ?? generateId() };
        (fields as any[]).forEach(f => {
          const el = modal.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(`[name="${f.key}"]`)!;
          const v = el.value;
          if (f.kind === 'number') {
            if (v !== '') item[f.key] = parseFloat(v);
          } else {
            if (v !== '') item[f.key] = v;
          }
        });

        if (itemIdx !== null) {
          itineraryState.days[dayIdx].items[itemIdx] = item;
        } else {
          itineraryState.days[dayIdx].items.push(item);
        }
        document.body.removeChild(overlay);
        renderItinerary();
      });
    }

    // Modal for editing a day's date and title
    function openDayModal(dayIdx: number) {
      const day = itineraryState.days[dayIdx];
      const overlay = document.createElement('div');
      overlay.className = 'fixed inset-0 bg-black/60 z-50 flex items-center justify-center px-4';

      const modal = document.createElement('div');
      modal.className = 'bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-5 w-full max-w-sm';
      modal.innerHTML = `
        <h3 class="text-sm font-semibold mb-4">Edit Day ${dayIdx + 1}</h3>
        <div class="flex flex-col gap-3">
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Date</label>
            <input name="date" type="date" value="${day.date}" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 min-h-[44px]" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Title</label>
            <input name="title" type="text" value="${day.title}" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 min-h-[44px]" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Notes (optional)</label>
            <textarea name="notes" rows="2" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 resize-none">${day.notes ?? ''}</textarea>
          </div>
        </div>
        <div class="flex gap-3 mt-5">
          <button type="button" id="day-modal-save" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg min-h-[44px]">Save</button>
          <button type="button" id="day-modal-cancel" class="px-4 py-2 border border-[var(--color-border)] text-sm rounded-lg min-h-[44px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]">Cancel</button>
        </div>
      `;

      overlay.appendChild(modal);
      document.body.appendChild(overlay);

      overlay.addEventListener('click', (e) => { if (e.target === overlay) document.body.removeChild(overlay); });
      modal.querySelector('#day-modal-cancel')!.addEventListener('click', () => document.body.removeChild(overlay));
      modal.querySelector('#day-modal-save')!.addEventListener('click', () => {
        const newDate = (modal.querySelector<HTMLInputElement>('[name="date"]')!).value;
        const newTitle = (modal.querySelector<HTMLInputElement>('[name="title"]')!).value.trim();
        const newNotes = (modal.querySelector<HTMLTextAreaElement>('[name="notes"]')!).value.trim();
        if (!newTitle) return;
        itineraryState.days[dayIdx].date = newDate;
        itineraryState.days[dayIdx].title = newTitle;
        itineraryState.days[dayIdx].notes = newNotes || undefined;
        document.body.removeChild(overlay);
        renderItinerary();
      });
    }

    function renderItinerary() {
      const container = document.getElementById('itinerary-editor')!;
      container.innerHTML = '';

      // Add Day button
      const addDayBtn = document.createElement('button');
      addDayBtn.type = 'button';
      addDayBtn.className = 'mb-4 px-4 py-2 border border-dashed border-[var(--color-border)] text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-blue-500 rounded-lg min-h-[44px] transition-colors';
      addDayBtn.textContent = '+ Add Day';
      addDayBtn.addEventListener('click', addDay);
      container.appendChild(addDayBtn);

      if (itineraryState.days.length === 0) {
        const empty = document.createElement('p');
        empty.className = 'text-[var(--color-text-muted)] text-sm';
        empty.textContent = 'No days yet. Click "+ Add Day" to start building the itinerary.';
        container.appendChild(empty);
        return;
      }

      function makeDayDropZone(insertIdx: number): HTMLDivElement {
        const zone = document.createElement('div');
        zone.dataset.dayDrop = String(insertIdx);
        zone.className = 'transition-all h-[6px]';
        zone.addEventListener('dragover', (e) => {
          if (!e.dataTransfer!.types.includes('application/x-day')) return;
          e.preventDefault();
          e.stopPropagation();
          zone.className = 'transition-all h-8 bg-blue-500/10 border-t-2 border-blue-500';
        });
        zone.addEventListener('dragleave', () => {
          zone.className = 'transition-all h-[6px]';
        });
        zone.addEventListener('drop', (e) => {
          if (!e.dataTransfer!.types.includes('application/x-day')) return;
          e.preventDefault();
          e.stopPropagation();
          zone.className = 'transition-all h-[6px]';
          const fromIdx = parseInt(e.dataTransfer!.getData('application/x-day'), 10);
          if (isNaN(fromIdx)) return;
          const days = itineraryState.days;
          const [moved] = days.splice(fromIdx, 1);
          const insertAt = fromIdx < insertIdx ? insertIdx - 1 : insertIdx;
          days.splice(insertAt, 0, moved);
          days.forEach((d, i) => { d.dayNumber = i + 1; });
          renderItinerary();
        });
        return zone;
      }

      function makeItemDropZone(dayIdx: number, insertIdx: number): HTMLDivElement {
        const zone = document.createElement('div');
        zone.dataset.itemDrop = `${dayIdx}:${insertIdx}`;
        zone.className = 'transition-all h-[6px]';
        zone.addEventListener('dragover', (e) => {
          if (!e.dataTransfer!.types.includes('text/plain')) return;
          e.preventDefault();
          e.stopPropagation();
          zone.className = 'transition-all h-8 bg-blue-500/10 border-t-2 border-blue-500';
        });
        zone.addEventListener('dragleave', () => {
          zone.className = 'transition-all h-[6px]';
        });
        zone.addEventListener('drop', (e) => {
          if (!e.dataTransfer!.types.includes('text/plain')) return;
          e.preventDefault();
          e.stopPropagation();
          zone.className = 'transition-all h-[6px]';
          const fromIdx = parseInt(e.dataTransfer!.getData('text/plain'), 10);
          if (isNaN(fromIdx)) return;
          const items = itineraryState.days[dayIdx].items;
          const [moved] = items.splice(fromIdx, 1);
          const insertAt = fromIdx < insertIdx ? insertIdx - 1 : insertIdx;
          items.splice(insertAt, 0, moved);
          manuallyReordered[dayIdx] = true;
          renderItinerary();
        });
        return zone;
      }

      // Top drop zone (insert before first day)
      container.appendChild(makeDayDropZone(0));

      itineraryState.days.forEach((day, dayIdx) => {
        const card = document.createElement('div');
        card.className = 'border border-[var(--color-border)] rounded-lg bg-[var(--color-surface)] overflow-hidden';
        card.draggable = true;
        card.addEventListener('dragstart', (e) => {
          e.dataTransfer!.setData('application/x-day', String(dayIdx));
          e.dataTransfer!.effectAllowed = 'move';
          card.classList.add('opacity-50');
        });
        card.addEventListener('dragend', () => {
          card.classList.remove('opacity-50');
        });

        // Day header
        const header = document.createElement('div');
        header.className = 'flex items-center gap-2 px-4 py-3 bg-[var(--color-bg-subtle)] border-b border-[var(--color-border)]';

        const dayLabel = document.createElement('span');
        dayLabel.className = 'text-xs font-semibold uppercase tracking-wide text-[var(--color-text-secondary)] shrink-0';
        dayLabel.textContent = `Day ${day.dayNumber}`;

        const dateLabel = document.createElement('span');
        dateLabel.className = 'text-xs text-[var(--color-text-muted)] shrink-0';
        dateLabel.textContent = day.date ? formatDate(day.date) : '—';

        const titleBtn = document.createElement('button');
        titleBtn.type = 'button';
        titleBtn.className = 'flex-1 text-left text-sm font-medium text-[var(--color-text-primary)] hover:text-blue-400 truncate min-h-[44px] transition-colors';
        titleBtn.textContent = day.title;
        titleBtn.title = 'Click to edit day';
        titleBtn.addEventListener('click', () => openDayModal(dayIdx));

        const reorderUp = document.createElement('button');
        reorderUp.type = 'button';
        reorderUp.className = 'p-1 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] disabled:opacity-30 min-h-[44px] px-2 transition-colors';
        reorderUp.textContent = '↑';
        reorderUp.title = 'Move day up';
        reorderUp.disabled = dayIdx === 0;
        reorderUp.addEventListener('click', () => moveDay(dayIdx, -1));

        const reorderDown = document.createElement('button');
        reorderDown.type = 'button';
        reorderDown.className = 'p-1 text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] disabled:opacity-30 min-h-[44px] px-2 transition-colors';
        reorderDown.textContent = '↓';
        reorderDown.title = 'Move day down';
        reorderDown.disabled = dayIdx === itineraryState.days.length - 1;
        reorderDown.addEventListener('click', () => moveDay(dayIdx, 1));

        const delDayBtn = document.createElement('button');
        delDayBtn.type = 'button';
        delDayBtn.className = 'p-1 text-red-400/60 hover:text-red-400 disabled:opacity-30 min-h-[44px] px-2 transition-colors';
        delDayBtn.textContent = '✕';
        delDayBtn.title = 'Delete day';
        delDayBtn.addEventListener('click', () => removeDay(dayIdx));

        const sortBtn = document.createElement('button');
        sortBtn.type = 'button';
        sortBtn.className = 'text-xs text-[var(--color-text-muted)] hover:text-blue-400 min-h-[44px] px-2 transition-colors';
        sortBtn.textContent = '↻ Sort';
        sortBtn.title = 'Re-sort items by start time';
        sortBtn.addEventListener('click', () => {
          manuallyReordered[dayIdx] = false;
          renderItinerary();
        });

        header.appendChild(dayLabel);
        header.appendChild(dateLabel);
        header.appendChild(titleBtn);
        header.appendChild(sortBtn);
        header.appendChild(reorderUp);
        header.appendChild(reorderDown);
        header.appendChild(delDayBtn);
        card.appendChild(header);

        if (!manuallyReordered[dayIdx]) {
          const withTime = day.items.filter((i: any) => i.startTime);
          const withoutTime = day.items.filter((i: any) => !i.startTime);
          withTime.sort((a: any, b: any) => a.startTime.localeCompare(b.startTime));
          day.items = [...withTime, ...withoutTime];
        }

        // Items list
        const itemsSection = document.createElement('div');
        itemsSection.className = 'p-3 flex flex-col gap-2';

        if (day.items && day.items.length > 0) {
          itemsSection.appendChild(makeItemDropZone(dayIdx, 0));
          day.items.forEach((item: any, itemIdx: number) => {
            const row = document.createElement('div');
            row.className = 'flex items-center gap-2 px-3 py-2 border border-[var(--color-border)] rounded-lg bg-[var(--color-bg-subtle)] hover:border-blue-500/50 transition-colors';
            row.draggable = true;
            row.addEventListener('dragstart', (e) => {
              e.dataTransfer!.setData('text/plain', String(itemIdx));
              e.dataTransfer!.effectAllowed = 'move';
              row.classList.add('opacity-50');
            });
            row.addEventListener('dragend', () => {
              row.classList.remove('opacity-50');
            });

            const emoji = document.createElement('span');
            emoji.className = 'text-base shrink-0';
            emoji.textContent = ITEM_TYPE_EMOJI[item.type] ?? '📋';

            const time = document.createElement('span');
            time.className = 'text-xs text-[var(--color-text-muted)] shrink-0 w-10';
            time.textContent = item.startTime ?? '';

            const itemTitle = document.createElement('button');
            itemTitle.type = 'button';
            itemTitle.className = 'flex-1 text-left text-sm text-[var(--color-text-primary)] hover:text-blue-400 truncate min-h-[44px] transition-colors';
            itemTitle.textContent = item.title;
            itemTitle.addEventListener('click', () => openItemModal(dayIdx, itemIdx));

            const statusBadge = document.createElement('span');
            const statusClass = ITEM_STATUS_COLOR[item.status] ?? 'text-[var(--color-text-muted)] bg-[var(--color-bg-subtle)]';
            statusBadge.className = `text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded shrink-0 ${statusClass}`;
            statusBadge.textContent = item.status ?? '';

            const itemUp = document.createElement('button');
            itemUp.type = 'button';
            itemUp.className = 'text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] disabled:opacity-30 min-h-[44px] px-1 transition-colors';
            itemUp.textContent = '↑';
            itemUp.disabled = itemIdx === 0;
            itemUp.addEventListener('click', () => moveItem(dayIdx, itemIdx, -1));

            const itemDown = document.createElement('button');
            itemDown.type = 'button';
            itemDown.className = 'text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] disabled:opacity-30 min-h-[44px] px-1 transition-colors';
            itemDown.textContent = '↓';
            itemDown.disabled = itemIdx === day.items.length - 1;
            itemDown.addEventListener('click', () => moveItem(dayIdx, itemIdx, 1));

            const delItemBtn = document.createElement('button');
            delItemBtn.type = 'button';
            delItemBtn.className = 'text-xs text-red-400/60 hover:text-red-400 min-h-[44px] px-1 transition-colors';
            delItemBtn.textContent = '✕';
            delItemBtn.addEventListener('click', () => removeItem(dayIdx, itemIdx));

            row.appendChild(emoji);
            row.appendChild(time);
            row.appendChild(itemTitle);
            row.appendChild(statusBadge);
            row.appendChild(itemUp);
            row.appendChild(itemDown);
            row.appendChild(delItemBtn);
            itemsSection.appendChild(row);
            itemsSection.appendChild(makeItemDropZone(dayIdx, itemIdx + 1));
          });
        } else {
          const empty = document.createElement('p');
          empty.className = 'text-xs text-[var(--color-text-muted)] px-1';
          empty.textContent = 'No items yet.';
          itemsSection.appendChild(empty);
        }

        // Add item button
        const addItemBtn = document.createElement('button');
        addItemBtn.type = 'button';
        addItemBtn.className = 'mt-1 text-sm text-blue-400 hover:text-blue-300 text-left min-h-[44px] px-1 transition-colors';
        addItemBtn.textContent = '+ Add Item';
        addItemBtn.addEventListener('click', () => openItemModal(dayIdx, null));
        itemsSection.appendChild(addItemBtn);

        card.appendChild(itemsSection);
        container.appendChild(card);
        container.appendChild(makeDayDropZone(dayIdx + 1));
      });
    }

