        const car: any = { id: (existing as any)?.id ?? generateId() };
        (fields as any[]).forEach(f => {
          const el = modal.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(`[name="${f.key}"]`)!;
          const v = el.value;
          if (f.kind === 'number') {
            if (v !== '') car[f.key] = parseFloat(v);
          } else {
            if (v !== '') car[f.key] = v;
          }
        });

        if (idx !== null) {
          logisticsState.rentalCars[idx] = car;
        } else {
          logisticsState.rentalCars.push(car);
        }
        document.body.removeChild(overlay);
        renderRentalCars();
      });
    }

    function renderRentalCars() {
      const container = panelRental;
      container.innerHTML = '';

      const addBtn = document.createElement('button');
      addBtn.type = 'button';
      addBtn.className = 'mb-4 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg min-h-[44px]';
      addBtn.textContent = '+ Add Rental Car';
      addBtn.addEventListener('click', () => openRentalCarModal(null));
      container.appendChild(addBtn);

      if (logisticsState.rentalCars.length === 0) {
        const empty = document.createElement('p');
        empty.className = 'text-sm text-[var(--color-text-muted)]';
        empty.textContent = 'No rental cars yet.';
        container.appendChild(empty);
        return;
      }

      logisticsState.rentalCars.forEach((car: any, carIdx: number) => {
        const card = document.createElement('div');
        card.className = 'border border-[var(--color-border)] rounded-lg p-4 mb-3 bg-[var(--color-surface)]';

        const statusClass = ITEM_STATUS_COLOR[car.status] ?? 'text-[var(--color-text-muted)] bg-[var(--color-bg-subtle)]';

        card.innerHTML = `
          <div class="flex items-start justify-between gap-3 mb-2">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-sm font-medium">${car.title}</span>
              ${car.carClass ? `<span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-secondary)]">${car.carClass}</span>` : ''}
              ${car.status ? `<span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded ${statusClass}">${car.status}</span>` : ''}
            </div>
            <div class="flex gap-2 shrink-0">
              <button type="button" class="rental-edit text-xs text-blue-400 hover:text-blue-300 min-h-[44px] px-1">Edit</button>
              <button type="button" class="rental-remove text-xs text-red-400/60 hover:text-red-400 min-h-[44px] px-1">Remove</button>
            </div>
          </div>
          ${car.pickupDate && car.dropoffDate ? `<p class="text-xs text-[var(--color-text-secondary)] mb-1">${car.pickupDate}${car.pickupTime ? ' ' + car.pickupTime : ''}${car.pickupLocation ? ' (' + car.pickupLocation + ')' : ''} → ${car.dropoffDate}${car.dropoffTime ? ' ' + car.dropoffTime : ''}${car.dropoffLocation ? ' (' + car.dropoffLocation + ')' : ''}</p>` : ''}
          ${car.vendor ? `<p class="text-xs text-[var(--color-text-secondary)] mb-1">🏢 ${car.vendor}</p>` : ''}
          ${car.confirmationNumber ? `<p class="text-xs text-[var(--color-text-secondary)] mb-1">Conf: ${car.confirmationNumber}</p>` : ''}
          ${car.cost != null ? `<p class="text-xs text-[var(--color-text-secondary)] mb-1">💰 ${car.cost} ${car.costCurrency ?? 'USD'}</p>` : ''}
          ${car.notes ? `<p class="text-xs text-[var(--color-text-muted)] mt-2 italic">${car.notes}</p>` : ''}
        `;

        card.querySelector('.rental-edit')!.addEventListener('click', () => openRentalCarModal(carIdx));
        card.querySelector('.rental-remove')!.addEventListener('click', () => {
          if (!confirm('Remove this rental car?')) return;
          logisticsState.rentalCars.splice(carIdx, 1);
          renderRentalCars();
        });

        container.appendChild(card);
      });
    }

    renderRentalCars();

    // --- Delete ---
    const deleteBtn = document.getElementById('delete-btn')!;
    deleteBtn.addEventListener('click', async () => {
      if (!confirm(`Delete trip "${tripId}"? This cannot be undone.`)) return;
      const res = await fetch('/api/admin/trips/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: tripId }),
        credentials: 'same-origin',
      });
      const data = await res.json() as { ok?: boolean; error?: string };
      if (data.ok) {
        window.location.href = '/admin/trips';
      } else {
        alert(data.error ?? 'Delete failed');
      }
    });
  </script>
</TripLayout>
