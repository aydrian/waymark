---
import type { GlobalPOI, PoiAssignment, Day } from '@itsaydrian/waymark-shared/types';
import PlacesMap from './PlacesMap.astro';
import PlaceCard from './PlaceCard.astro';

interface UnassignedPOI extends GlobalPOI {
  tripAdvisorNotes?: string;
  addedAt?: string;
}

interface AssignedPOI extends PoiAssignment {
  dayNumber: number;
}

interface Props {
  unassignedPOIs: UnassignedPOI[];
  assignedPOIs: AssignedPOI[];
  tripDays: Day[];
  tripId: string;
}

const { unassignedPOIs, assignedPOIs, tripDays, tripId } = Astro.props;

const allPOIs = [
  ...unassignedPOIs,
  ...assignedPOIs.map(a => a.poiSnapshot),
];

const cities = [...new Set(allPOIs.map(p => p.city))].sort();
const categories = [...new Set(allPOIs.map(p => p.category))].sort();

const dayOptions = tripDays.map(d => ({ number: d.dayNumber, date: d.date }));
---

<div>
  {/* Map showing all POIs */}
  <PlacesMap pois={allPOIs} />

  {/* Filter bar */}
  {(cities.length > 1 || categories.length > 1) && (
    <div class="px-4 pt-4 sm:px-6 space-y-2">
      {cities.length > 1 && (
        <div class="flex flex-wrap gap-1.5">
          {cities.map(city => (
            <button
              type="button"
              data-filter="city"
              data-value={city}
              class="filter-btn rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-subtle)] transition-colors"
            >{city}</button>
          ))}
        </div>
      )}
      {categories.length > 1 && (
        <div class="flex flex-wrap gap-1.5">
          {categories.map(cat => (
            <button
              type="button"
              data-filter="category"
              data-value={cat}
              class="filter-btn rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-medium text-[var(--color-text-secondary)] capitalize hover:bg-[var(--color-bg-subtle)] transition-colors"
            >{cat}</button>
          ))}
        </div>
      )}
    </div>
  )}

  {/* Assigned POIs Section */}
  {assignedPOIs.length > 0 && (
    <div class="px-4 py-4 sm:px-6">
      <h3 class="text-sm font-semibold text-[var(--color-text-secondary)] uppercase tracking-wide mb-3">
        On Your Itinerary
      </h3>
      <div id="assigned-poi-grid" class="grid grid-cols-1 gap-3">
        {assignedPOIs.map(assignment => (
          <div
            class="poi-card assigned-poi-card bg-[var(--color-surface)] rounded-lg border border-blue-500/30 p-4"
            data-city={assignment.poiSnapshot.city}
            data-category={assignment.poiSnapshot.category}
            data-poi-id={assignment.poiSnapshot.id}
            data-assignment-id={assignment.id}
          >
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-secondary)] ${assignment.allDay ? 'border border-blue-500/50' : ''}`}>
                    {assignment.allDay ? 'All Day' : `${assignment.startTime || '—'}${assignment.endTime ? ` - ${assignment.endTime}` : ''}`}
                  </span>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-400">
                    Day {assignment.dayNumber}
                  </span>
                </div>
                <h4 class="font-medium text-[var(--color-text-primary)] truncate">{assignment.poiSnapshot.name}</h4>
                <p class="text-xs text-[var(--color-text-secondary)]">{assignment.poiSnapshot.city} • <span class="capitalize">{assignment.poiSnapshot.category}</span></p>
                {assignment.poiSnapshot.tripAdvisorNotes && (
                  <p class="text-xs text-amber-500 mt-1 italic">{assignment.poiSnapshot.tripAdvisorNotes}</p>
                )}
                {assignment.poiSnapshot.clientNotes && (
                  <p class="text-xs text-blue-400 mt-1">{assignment.poiSnapshot.clientNotes}</p>
                )}
              </div>
              <div class="flex flex-col gap-1">
                <button
                  type="button"
                  class="edit-assignment-btn text-xs text-blue-400 hover:text-blue-300 px-2 py-1 rounded hover:bg-blue-500/10 transition-colors"
                  data-assignment={JSON.stringify(assignment)}
                >
                  Edit
                </button>
                <button
                  type="button"
                  class="remove-assignment-btn text-xs text-red-400 hover:text-red-300 px-2 py-1 rounded hover:bg-red-500/10 transition-colors"
                  data-assignment-id={assignment.id}
                >
                  Remove
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {/* Unassigned POIs Section */}
  <div class="px-4 py-4 sm:px-6 border-t border-[var(--color-border)]">
    <h3 class="text-sm font-semibold text-[var(--color-text-secondary)] uppercase tracking-wide mb-3">
      Available Places
    </h3>
    {unassignedPOIs.length === 0 ? (
      <p class="text-sm text-[var(--color-text-muted)]">
        {assignedPOIs.length > 0
          ? "All places have been added to your itinerary."
          : "No places of interest available for this trip yet."}
      </p>
    ) : (
      <div id="unassigned-poi-grid" class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {unassignedPOIs.map(poi => (
          <div
            class="poi-card unassigned-poi-card bg-[var(--color-surface)] rounded-lg border border-[var(--color-border)] p-4 hover:border-[var(--color-text-secondary)]/30 transition-colors"
            data-city={poi.city}
            data-category={poi.category}
            data-poi-id={poi.id}
          >
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <h4 class="font-medium text-[var(--color-text-primary)] truncate">{poi.name}</h4>
                <p class="text-xs text-[var(--color-text-secondary)]">{poi.city} • <span class="capitalize">{poi.category}</span></p>
                {poi.tripAdvisorNotes && (
                  <p class="text-xs text-amber-500 mt-1 italic">{poi.tripAdvisorNotes}</p>
                )}
                {poi.description && (
                  <p class="text-xs text-[var(--color-text-muted)] mt-1 line-clamp-2">{poi.description}</p>
                )}
              </div>
              <button
                type="button"
                class="assign-poi-btn text-xs bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded transition-colors whitespace-nowrap"
                data-poi={JSON.stringify({
                  id: poi.id,
                  name: poi.name,
                  city: poi.city,
                  category: poi.category,
                  advisorNotes: poi.advisorNotes,
                  tripAdvisorNotes: poi.tripAdvisorNotes,
                })}
              >
                Add to Itinerary
              </button>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

{/* Assignment Modal */}
<div id="assignment-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-[var(--color-surface)] rounded-lg border border-[var(--color-border)] max-w-md w-full p-6">
    <h3 class="text-lg font-semibold mb-4">Add to Itinerary</h3>
    <div id="modal-poi-info" class="mb-4 p-3 bg-[var(--color-bg-subtle)] rounded">
      <p class="font-medium" id="modal-poi-name"></p>
      <p class="text-xs text-[var(--color-text-secondary)]" id="modal-poi-details"></p>
    </div>

    <form id="assignment-form" class="space-y-4">
      <input type="hidden" id="modal-poi-id" name="poiId" />

      <div>
        <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Day</label>
        <select name="dayNumber" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500">
          {dayOptions.map(day => (
            <option value={day.number}>Day {day.number} ({day.date})</option>
          ))}
        </select>
      </div>

      <div class="flex items-center gap-3">
        <input type="checkbox" id="all-day-check" name="allDay" class="rounded border-[var(--color-border)]" />
        <label for="all-day-check" class="text-sm">All day event</label>
      </div>

      <div id="time-inputs" class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Start Time</label>
          <input type="time" name="startTime" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">End Time</label>
          <input type="time" name="endTime" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
      </div>

      <div>
        <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Your Notes (optional)</label>
        <textarea name="clientNotes" rows="2" placeholder="Reservation details, preferences, etc."
          class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm focus:outline-none focus:border-blue-500 resize-none"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="button" id="modal-cancel" class="flex-1 px-4 py-2 border border-[var(--color-border)] rounded-lg text-sm hover:bg-[var(--color-bg-subtle)] transition-colors">
          Cancel
        </button>
        <button type="submit" id="modal-submit" class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm transition-colors">
          Add to Day
        </button>
      </div>
    </form>

    <p id="modal-error" class="text-sm text-red-400 mt-3 hidden"></p>
  </div>
</div>

<script define:vars={{ tripId, dayOptions }}>
  // Filter functionality
  const activeCities = new Set();
  const activeCategories = new Set();

  function applyFilters() {
    const unassignedCards = document.querySelectorAll('.unassigned-poi-card');
    const assignedCards = document.querySelectorAll('.assigned-poi-card');

    [...unassignedCards, ...assignedCards].forEach(card => {
      const city = card.dataset.city ?? '';
      const category = card.dataset.category ?? '';
      const cityMatch = activeCities.size === 0 || activeCities.has(city);
      const catMatch = activeCategories.size === 0 || activeCategories.has(category);
      card.style.display = cityMatch && catMatch ? '' : 'none';
    });

    window.dispatchEvent(new CustomEvent('poi-filter-change', {
      detail: { cities: [...activeCities], categories: [...activeCategories] },
    }));
  }

  function setButtonActive(btn, active) {
    if (active) {
      btn.classList.add('bg-[var(--color-btn-active-bg)]', 'text-[var(--color-btn-active-text)]');
      btn.classList.remove('border-[var(--color-border)]', 'text-[var(--color-text-secondary)]');
    } else {
      btn.classList.remove('bg-[var(--color-btn-active-bg)]', 'text-[var(--color-btn-active-text)]');
      btn.classList.add('border-[var(--color-border)]', 'text-[var(--color-text-secondary)]');
    }
  }

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const type = btn.dataset.filter;
      const value = btn.dataset.value;
      const set = type === 'city' ? activeCities : activeCategories;

      if (set.has(value)) {
        set.delete(value);
        setButtonActive(btn, false);
      } else {
        set.add(value);
        setButtonActive(btn, true);
      }

      applyFilters();
    });
  });

  // Assignment modal
  const modal = document.getElementById('assignment-modal');
  const modalPoiName = document.getElementById('modal-poi-name');
  const modalPoiDetails = document.getElementById('modal-poi-details');
  const modalPoiId = document.getElementById('modal-poi-id');
  const modalCancel = document.getElementById('modal-cancel');
  const assignmentForm = document.getElementById('assignment-form');
  const modalError = document.getElementById('modal-error');
  const allDayCheck = document.getElementById('all-day-check');
  const timeInputs = document.getElementById('time-inputs');

  // Toggle time inputs based on all-day checkbox
  allDayCheck?.addEventListener('change', () => {
    timeInputs.style.display = allDayCheck.checked ? 'none' : 'grid';
  });

  // Open modal when clicking "Add to Itinerary"
  document.querySelectorAll('.assign-poi-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const poi = JSON.parse(btn.dataset.poi);
      modalPoiName.textContent = poi.name;
      modalPoiDetails.textContent = `${poi.city} • ${poi.category}${poi.tripAdvisorNotes ? ' • ' + poi.tripAdvisorNotes : ''}`;
      modalPoiId.value = poi.id;
      modalError.classList.add('hidden');
      modal.classList.remove('hidden');
    });
  });

  // Close modal
  modalCancel?.addEventListener('click', () => {
    modal.classList.add('hidden');
    assignmentForm.reset();
  });

  // Close on backdrop click
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.add('hidden');
      assignmentForm.reset();
    }
  });

  // Handle form submission
  assignmentForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('modal-submit');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding...';

    const formData = new FormData(assignmentForm);
    const payload = {
      poiId: formData.get('poiId'),
      dayNumber: parseInt(formData.get('dayNumber')),
      allDay: formData.has('allDay'),
      startTime: formData.get('startTime') || undefined,
      endTime: formData.get('endTime') || undefined,
      clientNotes: formData.get('clientNotes') || undefined,
    };

    try {
      const res = await fetch(`/api/trips/${tripId}/assignments`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (res.ok) {
        window.location.reload();
      } else {
        modalError.textContent = data.error || 'Failed to add to itinerary';
        modalError.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Add to Day';
      }
    } catch {
      modalError.textContent = 'Network error. Please try again.';
      modalError.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Add to Day';
    }
  });

  // Handle remove assignment
  document.querySelectorAll('.remove-assignment-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Remove this from your itinerary?')) return;

      const assignmentId = btn.dataset.assignmentId;
      btn.disabled = true;
      btn.textContent = 'Removing...';

      try {
        const res = await fetch(`/api/trips/${tripId}/assignments/${assignmentId}`, {
          method: 'DELETE',
        });

        if (res.ok) {
          window.location.reload();
        } else {
          alert('Failed to remove. Please try again.');
          btn.disabled = false;
          btn.textContent = 'Remove';
        }
      } catch {
        alert('Network error. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Remove';
      }
    });
  });

  // Handle edit assignment (simplified - just allow editing notes for now)
  document.querySelectorAll('.edit-assignment-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const assignment = JSON.parse(btn.dataset.assignment);
      // For now, just prompt for notes. Could be expanded to a full edit modal.
      const newNotes = prompt('Update your notes:', assignment.poiSnapshot.clientNotes || '');
      if (newNotes !== null) {
        fetch(`/api/trips/${tripId}/assignments/${assignment.id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ clientNotes: newNotes }),
        }).then(res => {
          if (res.ok) window.location.reload();
          else alert('Failed to update. Please try again.');
        }).catch(() => alert('Network error. Please try again.'));
      }
    });
  });
</script>
