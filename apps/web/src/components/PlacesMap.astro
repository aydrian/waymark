---
import type { PlaceOfInterest } from '@waymark/shared/types';
import 'leaflet/dist/leaflet.css';

interface Props {
  pois: PlaceOfInterest[];
}
const { pois } = Astro.props;
const coordPois = pois.filter(p => p.lat !== undefined && p.lng !== undefined);

const mapData = JSON.stringify({
  pois: coordPois.map(p => ({
    lat: p.lat,
    lng: p.lng,
    name: p.name,
    category: p.category,
    city: p.city,
    address: p.address,
  })),
});
---
{coordPois.length > 0 && (
  <div class="px-4 pt-4 sm:px-6">
    <div
      id="places-map"
      class="rounded-xl overflow-hidden border border-[var(--color-border)] h-52"
      data-map={mapData}
    ></div>
  </div>
)}

<script>
  import L from 'leaflet';

  const el = document.getElementById('places-map') as HTMLElement | null;
  if (el) {
    const { pois } = JSON.parse(el.dataset.map!) as {
      pois: { lat: number; lng: number; name: string; category: string; city: string; address?: string }[];
    };
    const isDark = document.documentElement.classList.contains('dark');

    const CATEGORY_COLORS: Record<string, string> = {
      restaurant: '#f97316',
      attraction: '#22c55e',
      shop: '#a855f7',
      outdoor: '#14b8a6',
      entertainment: '#ec4899',
      other: '#6b7280',
    };

    const map = L.map(el, { zoomControl: true, scrollWheelZoom: false });

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    function esc(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function getMarkerSize(zoom: number) {
      if (zoom <= 5) return { circleSize: 16, iconSize: 10, borderWidth: 1 };
      if (zoom <= 9) return { circleSize: 20, iconSize: 12, borderWidth: 1.5 };
      return { circleSize: 24, iconSize: 14, borderWidth: 2 };
    }

    function getMarkerBorder(isDark: boolean) {
      return isDark ? '#44403c' : '#ffffff';
    }

    // POI icon: map pin on colored circle (Lucide-style)
    function getPoiIcon(zoom: number, color: string, isDark: boolean) {
      const { circleSize, iconSize, borderWidth } = getMarkerSize(zoom);
      const border = getMarkerBorder(isDark);
      const iconOffset = (circleSize - iconSize) / 2;

      // Map pin SVG path (Lucide map-pin icon)
      const svgPath = 'M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z M12 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z';
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${iconSize}" height="${iconSize}" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="${svgPath}"/></svg>`;

      const html = `<div style="position:relative;width:${circleSize}px;height:${circleSize}px;">` +
        `<div style="position:absolute;inset:0;border-radius:50%;background:${color};border:${borderWidth}px solid ${border};box-shadow:0 2px 4px rgba(0,0,0,.4);"></div>` +
        `<div style="position:absolute;left:${iconOffset}px;top:${iconOffset}px;filter:drop-shadow(0 1px 1px rgba(0,0,0,0.3));">${svg}</div>` +
        `</div>`;

      return L.divIcon({
        className: '',
        html,
        iconSize: [circleSize, circleSize],
        iconAnchor: [circleSize / 2, circleSize / 2],
      });
    }

    // Track markers with their associated data for zoom updates and filtering
    interface MarkerData {
      marker: L.Marker;
      category: string;
      city: string;
    }

    const markerDataList: MarkerData[] = [];

    function createIcons(currentZoom: number) {
      for (const poi of pois) {
        const color = CATEGORY_COLORS[poi.category] ?? '#6b7280';
        const icon = getPoiIcon(currentZoom, color, isDark);
        const marker = L.marker([poi.lat, poi.lng], { icon });
        const detail = poi.address ?? poi.city;
        marker.bindPopup(`<strong>${esc(poi.name)}</strong>${detail ? `<br><span style="font-size:0.75rem">${esc(detail)}</span>` : ''}`);
        marker.addTo(map);

        markerDataList.push({
          marker,
          category: poi.category,
          city: poi.city,
        });
      }
    }

    // Create initial markers
    const initialZoom = map.getZoom() || 12;
    createIcons(initialZoom);

    // Update marker icons on zoom change
    map.on('zoomend', () => {
      const currentZoom = map.getZoom();
      for (const data of markerDataList) {
        const color = CATEGORY_COLORS[data.category] ?? '#6b7280';
        const newIcon = getPoiIcon(currentZoom, color, isDark);
        data.marker.setIcon(newIcon);
      }
    });

    // Set initial view
    const allMarkers = markerDataList.map(d => d.marker);
    if (allMarkers.length > 0) {
      const group = L.featureGroup(allMarkers);
      map.fitBounds(group.getBounds().pad(0.2));
    }

    // React to filter changes dispatched by PlacesTab
    window.addEventListener('poi-filter-change', (e: Event) => {
      const { cities, categories } = (e as CustomEvent<{ cities: string[]; categories: string[] }>).detail;
      markerDataList.forEach((data) => {
        const cityMatch = cities.length === 0 || cities.includes(data.city);
        const catMatch = categories.length === 0 || categories.includes(data.category);
        if (cityMatch && catMatch) {
          data.marker.addTo(map);
        } else {
          data.marker.remove();
        }
      });
    });
  }
</script>
