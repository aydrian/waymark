---
import type { Day } from '@itsaydrian/waymark-shared/types';

interface Props {
  days: Day[];
  activeFilter: 'all' | 'today' | number;
  tripId: string;
  isLive: boolean;
  currentDayNumber?: number;
}
const { days, activeFilter, tripId, isLive, currentDayNumber } = Astro.props;
---
<nav aria-label="Day filter" class="sticky top-0 z-10 bg-[var(--color-surface)] border-b border-[var(--color-border)] overflow-x-auto">
  <div class="flex gap-1 px-4 py-2 min-w-max">

    {/* All days */}
    <a
      href={`/trip/${tripId}`}
      aria-current={activeFilter === 'all' ? 'page' : undefined}
      class={`rounded-full px-3 py-1.5 text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-focus-ring)] ${
        activeFilter === 'all'
          ? 'bg-[var(--color-btn-active-bg)] text-[var(--color-btn-active-text)]'
          : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-subtle)]'
      }`}
    >All days</a>

    {/* Today button — only when live and current day exists */}
    {isLive && currentDayNumber !== undefined && (
      <a
        href={`/trip/${tripId}?day=today`}
        aria-current={activeFilter === 'today' ? 'page' : undefined}
        class={`rounded-full px-3 py-1.5 text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-today-text)] ${
          activeFilter === 'today'
            ? 'bg-[var(--color-today-active-bg)] text-white'
            : 'text-[var(--color-today-text)] border border-[var(--color-today-border)] hover:bg-[var(--color-today-hover-bg)]'
        }`}
      >Today</a>
    )}

    {/* Day N buttons */}
    {days.map(day => (
      <a
        href={`/trip/${tripId}?day=${day.dayNumber}`}
        aria-current={activeFilter === day.dayNumber ? 'page' : undefined}
        class={`flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-focus-ring)] ${
          activeFilter === day.dayNumber
            ? 'bg-[var(--color-btn-active-bg)] text-[var(--color-btn-active-text)]'
            : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-subtle)]'
        }`}
      >
        Day {day.dayNumber}
        {/* Today indicator dot */}
        {day.dayNumber === currentDayNumber && (
          <span
            aria-label="today"
            class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-today-dot)]"
          />
        )}
      </a>
    ))}

  </div>
</nav>
