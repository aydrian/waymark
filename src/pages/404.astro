---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Not Found — Waymark</title>
  </head>
  <body class="min-h-full bg-stone-50 text-stone-900 antialiased flex items-center justify-center px-4">
    <div class="text-center">
      <p class="text-5xl font-bold text-stone-200">404</p>
      <p class="mt-3 text-base font-semibold text-stone-700">Trip not found</p>
      <p class="mt-1 text-sm text-stone-400">This itinerary doesn't exist or may have been removed.</p>
    </div>
  </body>
</html>
