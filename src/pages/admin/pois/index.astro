---
import { env } from 'cloudflare:workers';
import { requireAdminSession } from '../../../lib/admin-auth';
import { listGlobalPOIs, listTrips } from '../../../lib/kv.js';
import TripLayout from '../../../layouts/TripLayout.astro';
import AdminNavbar from '../../../components/AdminNavbar.astro';

const redirect = await requireAdminSession(Astro.request, env.COOKIE_SIGNING_SECRET);
if (redirect) return redirect;

const pois = await listGlobalPOIs(env.TRIPS);
const trips = await listTrips(env.TRIPS);

// Sort by name
pois.sort((a, b) => a.name.localeCompare(b.name));

const cities = [...new Set(pois.map(p => p.city))].sort();
const categories = [...new Set(pois.map(p => p.category))].sort();
---
<TripLayout title="Admin — Global POIs">
  <AdminNavbar currentPage="pois" />
  <main class="max-w-4xl mx-auto px-4 py-10">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <h1 class="text-xl font-bold">Global Places of Interest</h1>
        <span class="text-sm text-[var(--color-text-secondary)]">({pois.length})</span>
      </div>
    </div>

    {/* Create New POI */}
    <div class="mb-8 p-4 border border-[var(--color-border)] rounded-lg bg-[var(--color-surface)]">
      <h2 class="text-sm font-semibold uppercase tracking-wide mb-4">Create New Global POI</h2>
      <form id="create-poi-form" class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Name *</label>
          <input name="name" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">City *</label>
          <input name="city" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Category *</label>
          <select name="category" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500">
            <option value="restaurant">Restaurant</option>
            <option value="attraction">Attraction</option>
            <option value="shop">Shop</option>
            <option value="outdoor">Outdoor</option>
            <option value="entertainment">Entertainment</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Address</label>
          <input name="address" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Website</label>
          <input name="website" type="url" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Google Maps URL</label>
          <input name="googleMapsUrl" type="url" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div class="col-span-2">
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Description</label>
          <textarea name="description" rows="2" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500 resize-none"></textarea>
        </div>
        <div class="col-span-2">
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Advisor Notes (visible to all trips using this POI)</label>
          <textarea name="advisorNotes" rows="2" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500 resize-none"></textarea>
        </div>
        <div class="col-span-2 flex items-center gap-3">
          <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 text-white text-sm font-medium rounded-lg transition-colors">
            Create Global POI
          </button>
          <p id="create-status" class="text-sm hidden"></p>
        </div>
      </form>
    </div>

    {/* Filters */}
    {(cities.length > 1 || categories.length > 1) && (
      <div class="mb-4 flex flex-wrap gap-2">
        {cities.length > 1 && (
          <select id="city-filter" class="px-3 py-1.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm">
            <option value="">All Cities</option>
            {cities.map(city => <option value={city}>{city}</option>)}
          </select>
        )}
        {categories.length > 1 && (
          <select id="category-filter" class="px-3 py-1.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-sm capitalize">
            <option value="">All Categories</option>
            {categories.map(cat => <option value={cat}>{cat}</option>)}
          </select>
        )}
      </div>
    )}

    {/* POI List */}
    <div id="poi-list" class="space-y-3">
      {pois.length === 0 ? (
        <p class="text-[var(--color-text-muted)]">No global POIs yet. Create one above.</p>
      ) : (
        pois.map(poi => (
          <div
            class="poi-item p-4 border border-[var(--color-border)] rounded-lg bg-[var(--color-surface)] hover:border-[var(--color-text-secondary)]/30 transition-colors"
            data-city={poi.city}
            data-category={poi.category}
            data-poi-id={poi.id}
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="font-medium text-[var(--color-text-primary)]">{poi.name}</h3>
                  <span class="text-[10px] uppercase tracking-wide px-1.5 py-0.5 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-secondary)] capitalize">
                    {poi.category}
                  </span>
                  <span class="text-[10px] px-1.5 py-0.5 rounded bg-[var(--color-bg-subtle)] text-[var(--color-text-secondary)]">
                    {poi.city}
                  </span>
                </div>
                {poi.address && <p class="text-xs text-[var(--color-text-secondary)] mb-1">{poi.address}</p>}
                {poi.description && <p class="text-xs text-[var(--color-text-muted)] mb-1">{poi.description}</p>}
                {poi.advisorNotes && (
                  <p class="text-xs text-amber-500 italic">Advisor: {poi.advisorNotes}</p>
                )}
                <div class="flex items-center gap-3 mt-2">
                  {poi.website && (
                    <a href={poi.website} target="_blank" rel="noopener" class="text-xs text-blue-400 hover:text-blue-300">Website</a>
                  )}
                  {poi.googleMapsUrl && (
                    <a href={poi.googleMapsUrl} target="_blank" rel="noopener" class="text-xs text-blue-400 hover:text-blue-300">Maps</a>
                  )}
                </div>
              </div>
              <div class="flex flex-col gap-2 items-end">
                <select
                  class="add-to-trip-select text-xs px-2 py-1 rounded border border-[var(--color-border)] bg-[var(--color-surface)]"
                  data-poi-id={poi.id}
                >
                  <option value="">Add to trip...</option>
                  {trips.map(trip => <option value={trip.id}>{trip.title}</option>)}
                </select>
                <div class="flex gap-2">
                  <button
                    type="button"
                    class="edit-poi-btn text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] px-2 py-1"
                    data-poi={JSON.stringify(poi)}
                  >
                    Edit
                  </button>
                  <button
                    type="button"
                    class="delete-poi-btn text-xs text-red-400 hover:text-red-300 px-2 py-1"
                    data-poi-id={poi.id}
                    data-poi-name={poi.name}
                  >
                    Delete
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))
      )}
    </div>
  </div>

  {/* Edit Modal */}
  <div id="edit-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-[var(--color-surface)] rounded-lg border border-[var(--color-border)] max-w-lg w-full p-6 max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-semibold mb-4">Edit Global POI</h3>
      <form id="edit-poi-form" class="space-y-3">
        <input type="hidden" id="edit-poi-id" name="id" />
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Name</label>
          <input name="name" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">City</label>
            <input name="city" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Category</label>
            <select name="category" required class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500">
              <option value="restaurant">Restaurant</option>
              <option value="attraction">Attraction</option>
              <option value="shop">Shop</option>
              <option value="outdoor">Outdoor</option>
              <option value="entertainment">Entertainment</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Address</label>
          <input name="address" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Website</label>
            <input name="website" type="url" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Google Maps URL</label>
            <input name="googleMapsUrl" type="url" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500" />
          </div>
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Description</label>
          <textarea name="description" rows="2" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500 resize-none"></textarea>
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wide text-[var(--color-text-secondary)] mb-1">Advisor Notes</label>
          <textarea name="advisorNotes" rows="2" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-sm focus:outline-none focus:border-blue-500 resize-none"></textarea>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="edit-cancel" class="flex-1 px-4 py-2 border border-[var(--color-border)] rounded-lg text-sm hover:bg-[var(--color-bg-subtle)] transition-colors">
            Cancel
          </button>
          <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm transition-colors">
            Save Changes
          </button>
        </div>
      </form>
      <p id="edit-error" class="text-sm text-red-400 mt-3 hidden"></p>
    </div>
  </div>

  <script>
    // Create POI
    const createForm = document.getElementById('create-poi-form');
    const createStatus = document.getElementById('create-status');

    createForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = createForm.querySelector('button[type=submit]') as HTMLButtonElement;
      submitBtn.disabled = true;
      createStatus.classList.add('hidden');

      const formData = new FormData(createForm);
      const payload = Object.fromEntries(
        Array.from(formData.entries()).map(([k, v]) => [k, v || undefined])
      );

      try {
        const res = await fetch('/api/admin/pois', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();

        if (res.ok) {
          createStatus.textContent = 'Created! Reloading...';
          createStatus.className = 'text-sm text-green-400';
          createStatus.classList.remove('hidden');
          window.location.reload();
        } else {
          createStatus.textContent = data.error || 'Failed to create';
          createStatus.className = 'text-sm text-red-400';
          createStatus.classList.remove('hidden');
          submitBtn.disabled = false;
        }
      } catch {
        createStatus.textContent = 'Network error';
        createStatus.className = 'text-sm text-red-400';
        createStatus.classList.remove('hidden');
        submitBtn.disabled = false;
      }
    });

    // Filters
    const cityFilter = document.getElementById('city-filter') as HTMLSelectElement;
    const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;

    function applyFilters() {
      const city = cityFilter?.value;
      const category = categoryFilter?.value;

      document.querySelectorAll('.poi-item').forEach(item => {
        const itemCity = item.getAttribute('data-city');
        const itemCategory = item.getAttribute('data-category');
        const cityMatch = !city || itemCity === city;
        const categoryMatch = !category || itemCategory === category;
        (item as HTMLElement).style.display = cityMatch && categoryMatch ? '' : 'none';
      });
    }

    cityFilter?.addEventListener('change', applyFilters);
    categoryFilter?.addEventListener('change', applyFilters);

    // Add to trip
    document.querySelectorAll('.add-to-trip-select').forEach(select => {
      select.addEventListener('change', async (e) => {
        const target = e.target as HTMLSelectElement;
        const tripId = target.value;
        const poiId = target.getAttribute('data-poi-id');

        if (!tripId) return;

        target.disabled = true;

        try {
          const res = await fetch(`/api/admin/trips/${tripId}/pois`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ poiId }),
          });

          if (res.ok) {
            alert('Added to trip!');
          } else {
            const data = await res.json();
            alert(data.error || 'Failed to add to trip');
          }
        } catch {
          alert('Network error');
        }

        target.value = '';
        target.disabled = false;
      });
    });

    // Edit modal
    const editModal = document.getElementById('edit-modal');
    const editForm = document.getElementById('edit-poi-form') as HTMLFormElement;
    const editCancel = document.getElementById('edit-cancel');
    const editError = document.getElementById('edit-error');

    document.querySelectorAll('.edit-poi-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const poi = JSON.parse(btn.getAttribute('data-poi')!);
        (document.getElementById('edit-poi-id') as HTMLInputElement).value = poi.id;
        (editForm.elements.namedItem('name') as HTMLInputElement).value = poi.name;
        (editForm.elements.namedItem('city') as HTMLInputElement).value = poi.city;
        (editForm.elements.namedItem('category') as HTMLSelectElement).value = poi.category;
        (editForm.elements.namedItem('address') as HTMLInputElement).value = poi.address || '';
        (editForm.elements.namedItem('website') as HTMLInputElement).value = poi.website || '';
        (editForm.elements.namedItem('googleMapsUrl') as HTMLInputElement).value = poi.googleMapsUrl || '';
        (editForm.elements.namedItem('description') as HTMLTextAreaElement).value = poi.description || '';
        (editForm.elements.namedItem('advisorNotes') as HTMLTextAreaElement).value = poi.advisorNotes || '';

        editError?.classList.add('hidden');
        editModal?.classList.remove('hidden');
      });
    });

    editCancel?.addEventListener('click', () => {
      editModal?.classList.add('hidden');
    });

    editModal?.addEventListener('click', (e) => {
      if (e.target === editModal) editModal.classList.add('hidden');
    });

    editForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = editForm.querySelector('button[type=submit]') as HTMLButtonElement;
      submitBtn.disabled = true;
      editError?.classList.add('hidden');

      const id = (document.getElementById('edit-poi-id') as HTMLInputElement).value;
      const formData = new FormData(editForm);
      const payload = Object.fromEntries(
        Array.from(formData.entries()).filter(([_, v]) => v).map(([k, v]) => [k, v])
      );

      try {
        const res = await fetch(`/api/admin/pois/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          editError.textContent = data.error || 'Failed to update';
          editError.className = 'text-sm text-red-400 mt-3';
          editError.classList.remove('hidden');
          submitBtn.disabled = false;
        }
      } catch {
        editError.textContent = 'Network error';
        editError.className = 'text-sm text-red-400 mt-3';
        editError.classList.remove('hidden');
        submitBtn.disabled = false;
      }
    });

    // Delete
    document.querySelectorAll('.delete-poi-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const poiId = btn.getAttribute('data-poi-id');
        const poiName = btn.getAttribute('data-poi-name');

        if (!confirm(`Delete "${poiName}"? This cannot be undone.`)) return;

        try {
          const res = await fetch(`/api/admin/pois/${poiId}`, { method: 'DELETE' });

          if (res.ok) {
            (btn.closest('.poi-item') as HTMLElement)?.remove();
          } else {
            const data = await res.json();
            alert(data.error || 'Failed to delete');
          }
        } catch {
          alert('Network error');
        }
      });
    });
  </script>
</main>
</TripLayout>
