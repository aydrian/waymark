---
import type { Day } from '../types/itinerary';
import TimelineItem from './TimelineItem.astro';
import CurrentDayBadge from './CurrentDayBadge.astro';

interface Props {
  day: Day;
  isToday?: boolean;
}
const { day, isToday = false } = Astro.props;

const fmt = (d: string) => new Date(d + 'T00:00:00Z').toLocaleDateString('en-US', {
  weekday: 'short', month: 'short', day: 'numeric',
});
---
<section class="mb-6">
  <div class="px-4 py-3 sm:px-6">
    <div class="flex items-baseline gap-2 flex-wrap">
      <span class="text-xs font-bold uppercase tracking-widest text-stone-400">Day {day.dayNumber}</span>
      <span class="text-xs text-stone-400">{fmt(day.date)}</span>
      {isToday && <CurrentDayBadge />}
    </div>
    <h2 class="text-base font-semibold text-stone-900 mt-0.5">{day.title}</h2>
    {day.notes && (
      <p class="text-sm text-stone-500 mt-1">{day.notes}</p>
    )}
  </div>
  <div class="bg-white border-y border-stone-200 px-4 divide-y divide-stone-100 sm:px-6">
    {day.items.length === 0 ? (
      <p class="py-4 text-sm text-stone-400 italic">No items for this day.</p>
    ) : (
      day.items.map(item => <TimelineItem item={item} />)
    )}
  </div>
</section>
