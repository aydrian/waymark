---
import type { HotelStay } from '../types/itinerary';

interface Props {
  activeStay: HotelStay | null;
  checkinToday: HotelStay | null;
  checkoutToday: HotelStay | null;
}

const { activeStay, checkinToday, checkoutToday } = Astro.props;

const hasContent = activeStay !== null || checkoutToday !== null;
if (!hasContent) return;

const isCheckinDay = activeStay !== null && checkinToday !== null && activeStay.id === checkinToday.id;
const isIntermediateDay = activeStay !== null && !isCheckinDay;
---

<div class="mx-4 mb-3 mt-1 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] sm:mx-6">
  {checkoutToday && (
    <div class="flex items-center gap-2 px-3 py-2 text-sm text-[var(--color-text-secondary)]">
      <span class="text-base leading-none">🔑</span>
      <span>
        Checking out of <span class="font-medium text-[var(--color-text-primary)]">{checkoutToday.title}</span>
        {checkoutToday.checkoutTime && <> at {checkoutToday.checkoutTime}</>}
      </span>
    </div>
  )}

  {activeStay && (
    <div class:list={[
      'px-3 py-2',
      checkoutToday ? 'border-t border-[var(--color-border-subtle)]' : '',
    ]}>
      <div class="flex items-start gap-2">
        <span class="mt-0.5 text-base leading-none">🏨</span>
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-sm font-medium text-[var(--color-text-primary)]">{activeStay.title}</span>
            {isCheckinDay && (
              <span class="text-xs text-[var(--color-text-muted)]">Checking in tonight</span>
            )}
            {isIntermediateDay && (
              <span class="text-xs text-[var(--color-text-muted)]">Staying tonight</span>
            )}
          </div>
          {activeStay.address && (
            <p class="mt-0.5 text-xs text-[var(--color-text-secondary)] truncate">{activeStay.address}</p>
          )}
          {isCheckinDay && (
            <p class="mt-0.5 text-xs text-[var(--color-text-muted)]">
              {activeStay.checkinTime && <>Check-in {activeStay.checkinTime}</>}
              {activeStay.checkinTime && activeStay.confirmationNumber && <> · </>}
              {activeStay.confirmationNumber && <>Conf: {activeStay.confirmationNumber}</>}
            </p>
          )}
        </div>
      </div>
    </div>
  )}
</div>
