---
import type { TripItem } from '../types/itinerary';
import type { GeneratedItem } from '../lib/trip-state';
import 'leaflet/dist/leaflet.css';

interface Props {
  items: (TripItem | GeneratedItem)[];
  centerLat?: number;
  centerLng?: number;
  zoom?: number;
}
const { items, centerLat, centerLng, zoom } = Astro.props;
const coordItems = items.filter(i => i.lat !== undefined && i.lng !== undefined);

const mapData = JSON.stringify({
  items: coordItems.map(i => {
    const gi = i as GeneratedItem;
    return {
      lat: i.lat,
      lng: i.lng,
      title: i.title,
      type: i.type,
      location: i.location,
      address: i.address,
      _legType: gi._legType,
    };
  }),
  center: centerLat !== undefined && centerLng !== undefined ? [centerLat, centerLng] : null,
  zoom: zoom ?? null,
});
---
{coordItems.length > 0 && (
  <div class="px-4 pt-4 sm:px-6">
    <div
      id="trip-map"
      class="rounded-xl overflow-hidden border border-[var(--color-border)] h-52"
      data-map={mapData}
    ></div>
  </div>
)}

<script>
  import L from 'leaflet';

  const el = document.getElementById('trip-map') as HTMLElement | null;
  if (el) {
    const { items, center, zoom } = JSON.parse(el.dataset.map!);
    const isDark = document.documentElement.classList.contains('dark');

    const map = L.map(el, { zoomControl: true, scrollWheelZoom: false });

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    const TYPE_COLORS: Record<string, string> = {
      hotel: '#3b82f6',
      restaurant: '#f97316',
      activity: '#22c55e',
      transport: '#6b7280',
      transfer: '#6b7280',
      note: '#eab308',
    };

    function getMarkerSize(zoom: number) {
      if (zoom <= 5) return { circleSize: 16, iconSize: 10, borderWidth: 1 };
      if (zoom <= 9) return { circleSize: 20, iconSize: 12, borderWidth: 1.5 };
      return { circleSize: 24, iconSize: 14, borderWidth: 2 };
    }

    function getMarkerBorder(isDark: boolean) {
      return isDark ? '#44403c' : '#ffffff';
    }

    // Hotel icon: building symbol (Lucide-style)
    function getHotelIcon(zoom: number, isDark: boolean) {
      const { circleSize, iconSize, borderWidth } = getMarkerSize(zoom);
      const border = getMarkerBorder(isDark);
      const iconOffset = (circleSize - iconSize) / 2;

      // Building SVG path (Lucide hotel icon)
      const svgPath = 'M2 22V9.5a2.5 2.5 0 0 1 5 0V22M7 9.5V5a2 2 0 0 1 4 0v14M12 5V2a2 2 0 0 1 4 0v3M15 2v20M19 9v13';
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${iconSize}" height="${iconSize}" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="${svgPath}"/></svg>`;

      const html = `<div style="position:relative;width:${circleSize}px;height:${circleSize}px;">` +
        `<div style="position:absolute;inset:0;border-radius:50%;background:#3b82f6;border:${borderWidth}px solid ${border};box-shadow:0 2px 4px rgba(0,0,0,.4);"></div>` +
        `<div style="position:absolute;left:${iconOffset}px;top:${iconOffset}px;filter:drop-shadow(0 1px 1px rgba(0,0,0,0.3));">${svg}</div>` +
        `</div>`;

      return L.divIcon({
        className: '',
        html,
        iconSize: [circleSize, circleSize],
        iconAnchor: [circleSize / 2, circleSize / 2],
      });
    }

    // Standard icon: map pin (Lucide-style)
    function getStandardIcon(zoom: number, color: string, isDark: boolean) {
      const { circleSize, iconSize, borderWidth } = getMarkerSize(zoom);
      const border = getMarkerBorder(isDark);
      const iconOffset = (circleSize - iconSize) / 2;

      // Map pin SVG path (Lucide map-pin icon)
      const svgPath = 'M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z M12 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z';
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${iconSize}" height="${iconSize}" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="${svgPath}"/></svg>`;

      const html = `<div style="position:relative;width:${circleSize}px;height:${circleSize}px;">` +
        `<div style="position:absolute;inset:0;border-radius:50%;background:${color};border:${borderWidth}px solid ${border};box-shadow:0 2px 4px rgba(0,0,0,.4);"></div>` +
        `<div style="position:absolute;left:${iconOffset}px;top:${iconOffset}px;filter:drop-shadow(0 1px 1px rgba(0,0,0,0.3));">${svg}</div>` +
        `</div>`;

      return L.divIcon({
        className: '',
        html,
        iconSize: [circleSize, circleSize],
        iconAnchor: [circleSize / 2, circleSize / 2],
      });
    }

    // Track markers with their associated data for zoom updates
    interface MarkerData {
      marker: L.Marker;
      type: string;
      isTransportLeg: boolean;
    }

    const markerDataList: MarkerData[] = [];

    function createIcons(currentZoom: number) {
      for (const item of items) {
        const isTransportLeg = item._legType === 'departure' || item._legType === 'arrival';
        const color = isTransportLeg ? '#6366f1' : (TYPE_COLORS[item.type] ?? '#6b7280');

        const icon = item.type === 'hotel'
          ? getHotelIcon(currentZoom, isDark)
          : getStandardIcon(currentZoom, color, isDark);

        const marker = L.marker([item.lat, item.lng], { icon });
        const detail = item.address ?? item.location;
        const popup = `<strong>${item.title}</strong>${detail ? `<br><span style="font-size:0.75rem">${detail}</span>` : ''}`;
        marker.bindPopup(popup);
        marker.addTo(map);

        markerDataList.push({
          marker,
          type: item.type,
          isTransportLeg,
        });
      }
    }

    // Create initial markers
    const initialZoom = zoom ?? 12;
    createIcons(initialZoom);

    // Update marker icons on zoom change
    map.on('zoomend', () => {
      const currentZoom = map.getZoom();
      for (const data of markerDataList) {
        const color = data.isTransportLeg ? '#6366f1' : (TYPE_COLORS[data.type] ?? '#6b7280');
        const newIcon = data.type === 'hotel'
          ? getHotelIcon(currentZoom, isDark)
          : getStandardIcon(currentZoom, color, isDark);
        data.marker.setIcon(newIcon);
      }
    });

    // Set initial view
    const allMarkers = markerDataList.map(d => d.marker);
    if (center) {
      map.setView(center, initialZoom);
    } else if (allMarkers.length > 0) {
      const group = L.featureGroup(allMarkers);
      map.fitBounds(group.getBounds().pad(0.2));
    }
  }
</script>
