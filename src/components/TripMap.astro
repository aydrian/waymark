---
import type { TripItem } from '../types/itinerary';
import type { GeneratedItem } from '../lib/trip-state';
import 'leaflet/dist/leaflet.css';

interface Props {
  items: (TripItem | GeneratedItem)[];
  centerLat?: number;
  centerLng?: number;
  zoom?: number;
}
const { items, centerLat, centerLng, zoom } = Astro.props;
const coordItems = items.filter(i => i.lat !== undefined && i.lng !== undefined);

const mapData = JSON.stringify({
  items: coordItems.map(i => {
    const gi = i as GeneratedItem;
    return {
      lat: i.lat,
      lng: i.lng,
      title: i.title,
      type: i.type,
      location: i.location,
      address: i.address,
      _legType: gi._legType,
    };
  }),
  center: centerLat !== undefined && centerLng !== undefined ? [centerLat, centerLng] : null,
  zoom: zoom ?? null,
});
---
{coordItems.length > 0 && (
  <div class="px-4 pt-4 sm:px-6">
    <div
      id="trip-map"
      class="rounded-xl overflow-hidden border border-[var(--color-border)] h-52"
      data-map={mapData}
    ></div>
  </div>
)}

<script>
  import L from 'leaflet';

  const el = document.getElementById('trip-map') as HTMLElement | null;
  if (el) {
    const { items, center, zoom } = JSON.parse(el.dataset.map!);
    const isDark = document.documentElement.classList.contains('dark');
    const markerBorder = isDark ? '#44403c' : '#ffffff';

    const map = L.map(el, { zoomControl: true, scrollWheelZoom: false });

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    const TYPE_COLORS: Record<string, string> = {
      hotel: '#3b82f6',
      restaurant: '#f97316',
      activity: '#22c55e',
      transport: '#6b7280',
      transfer: '#6b7280',
      note: '#eab308',
    };

    function hotelDivIcon() {
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 22v-6.57"/><path d="M12 11h.01"/><path d="M12 7h.01"/><path d="M14 15.43V22"/><path d="M15 16a5 5 0 0 0-6 0"/><path d="M16 11h.01"/><path d="M16 7h.01"/><path d="M8 11h.01"/><path d="M8 7h.01"/><rect x="4" y="2" width="16" height="20" rx="2"/></svg>`;
      return L.divIcon({
        className: '',
        html: `<div style="width:20px;height:20px;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.4))">${svg}</div>`,
        iconSize: [20, 20],
        iconAnchor: [10, 10],
      });
    }

    const markers: L.Marker[] = [];
    for (const item of items) {
      const isTransportLeg = item._legType === 'departure' || item._legType === 'arrival';
      const icon = item.type === 'hotel'
        ? hotelDivIcon()
        : (() => {
            const color = isTransportLeg ? '#6366f1' : (TYPE_COLORS[item.type] ?? '#6b7280');
            return L.divIcon({
              className: '',
              html: `<div style="width:12px;height:12px;border-radius:50%;background:${color};border:2px solid ${markerBorder};box-shadow:0 1px 3px rgba(0,0,0,.4)"></div>`,
              iconSize: [12, 12],
              iconAnchor: [6, 6],
            });
          })();
      const marker = L.marker([item.lat, item.lng], { icon });
      const detail = item.address ?? item.location;
      const popup = `<strong>${item.title}</strong>${detail ? `<br><span style="font-size:0.75rem">${detail}</span>` : ''}`;
      marker.bindPopup(popup);
      marker.addTo(map);
      markers.push(marker);
    }

    if (center) {
      map.setView(center, zoom ?? 12);
    } else if (markers.length > 0) {
      const group = L.featureGroup(markers);
      map.fitBounds(group.getBounds().pad(0.2));
    }
  }
</script>
