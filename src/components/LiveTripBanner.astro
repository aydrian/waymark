---
interface Props {
  currentDayNumber: number;
  totalDays: number;
  localDate: string;
  tripId: string;
}
const { currentDayNumber, totalDays, localDate, tripId } = Astro.props;
---
<div role="status" aria-label="Live trip status" class="bg-[var(--color-note-bg)] border-b border-[var(--color-note-border)] px-4 py-3 flex flex-wrap items-center justify-between gap-x-4 gap-y-1">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
    <span class="inline-flex items-center rounded-full bg-[var(--color-note-badge-bg)] px-2 py-0.5 text-xs font-bold uppercase tracking-wider text-[var(--color-note-badge-text)]">
      Live
    </span>
    <span class="text-sm font-medium text-[var(--color-text-primary)]">
      You're on Day {currentDayNumber} of {totalDays}
    </span>
    <span class="text-sm text-[var(--color-text-secondary)]">
      Local date: {localDate}
    </span>
  </div>
  <a
    href={`/trip/${tripId}?day=today`}
    class="text-sm font-medium text-[var(--color-note-link)] hover:text-[var(--color-note-link-hover)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-note-link)] rounded whitespace-nowrap"
  >
    Jump to today <span aria-hidden="true">→</span>
  </a>
</div>
