---
import StatusBadge from './StatusBadge.astro';
import type { ItemStatus } from '../types/itinerary';
import { formatCurrencySmart, getCurrencySymbol } from '../lib/exchange-rates';

export interface OriginalCost {
  amount: number;
  currency: string;
}

export interface ConvertedCost {
  amount: number;
  currency: string;
  rate: number;
  rateSource: 'frankfurter' | 'fawaz' | 'cache';
  rateDate: string;
}

export interface ExpenseItem {
  id: string;
  title: string;
  status: ItemStatus;
  originalCost: OriginalCost;
  convertedCost?: ConvertedCost;
  dateRange?: string;
  vendor?: string;
}

export interface ExpenseCategory {
  name: string;
  items: ExpenseItem[];
  originalSubtotal: { amount: number; currency: string };
  convertedSubtotal?: { amount: number; currency: string };
}

interface Props {
  categories: ExpenseCategory[];
  grandTotalOriginal: { amount: number; currency: string };
  grandTotalConverted: { amount: number; currency: string };
  exchangeRatesUsed: Array<{ from: string; to: string; rate: number; source: string; date: string }>;
}

const { categories, grandTotalOriginal, grandTotalConverted, exchangeRatesUsed } = Astro.props;

const hasExpenses = categories.some(c => c.items.length > 0);

// Category display order and icons
const categoryMeta: Record<string, { icon: string; label: string }> = {
  lodging: { icon: '🏨', label: 'Lodging' },
  travel: { icon: '✈️', label: 'Travel' },
  'rental-cars': { icon: '🚗', label: 'Rental Cars' },
  activities: { icon: '🎯', label: 'Activities' },
  dining: { icon: '🍽️', label: 'Dining' },
  transfers: { icon: '🚐', label: 'Transfers' },
  other: { icon: '📝', label: 'Other' },
};

// Check if we have multiple currencies
const hasMultipleCurrencies = exchangeRatesUsed.length > 0;
const allCurrencies = [...new Set(categories.flatMap(c => c.items.map(i => i.originalCost.currency)))];
---

{!hasExpenses ? (
  <div class="px-4 py-12 text-center sm:px-6">
    <p class="text-sm text-[var(--color-text-muted)]">No expenses have been added to this trip yet.</p>
    <p class="text-xs text-[var(--color-text-muted)] mt-2">
      Costs can be added to hotels, transport, activities, and other items.
    </p>
  </div>
) : (
  <div class="px-4 py-6 sm:px-6 space-y-6">
    {/* Exchange rates summary - show if multiple currencies */}
    {hasMultipleCurrencies && (
      <div class="bg-[var(--color-bg-subtle)] rounded-lg p-3 text-xs">
        <p class="font-medium text-[var(--color-text-secondary)] mb-1">Exchange Rates Used</p>
        <div class="flex flex-wrap gap-x-4 gap-y-1">
          {exchangeRatesUsed.map(rate => (
            <span class="text-[var(--color-text-muted)]">
              1 {rate.from} = {rate.rate.toFixed(4)} {rate.to}
              <span class="text-[var(--color-text-muted)]/60 ml-1">({rate.source})</span>
            </span>
          ))}
        </div>
      </div>
    )}

    {/* Category sections */}
    {categories.map(category => (
      category.items.length > 0 && (
        <section class="border border-[var(--color-border)] rounded-lg overflow-hidden">
          {/* Category header */}
          <div class="flex items-center justify-between px-4 py-3 bg-[var(--color-bg-subtle)] border-b border-[var(--color-border)]">
            <div class="flex items-center gap-2">
              <span class="text-lg" aria-hidden="true">
                {categoryMeta[category.name]?.icon || '📋'}
              </span>
              <h3 class="text-sm font-semibold text-[var(--color-text-primary)]">
                {categoryMeta[category.name]?.label || category.name}
              </h3>
              <span class="rounded-full bg-[var(--color-bg-muted)] px-2 py-0.5 text-xs text-[var(--color-text-muted)]">
                {category.items.length}
              </span>
            </div>
            <div class="text-right">
              {category.convertedSubtotal && category.originalSubtotal.currency !== category.convertedSubtotal.currency && (
                <span class="block text-xs text-[var(--color-text-muted)]">
                  {formatCurrencySmart(category.originalSubtotal.amount, category.originalSubtotal.currency)}
                </span>
              )}
              <span class="text-sm font-semibold text-[var(--color-text-primary)]">
                {formatCurrencySmart(category.convertedSubtotal?.amount ?? category.originalSubtotal.amount, 'USD')}
              </span>
            </div>
          </div>

          {/* Items list */}
          <div class="divide-y divide-[var(--color-border)]">
            {category.items.map(item => (
              <div class="flex items-center justify-between px-4 py-3 hover:bg-[var(--color-bg-subtle)] transition-colors">
                <div class="flex-1 min-w-0 pr-4">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-sm font-medium text-[var(--color-text-primary)] truncate">
                      {item.title}
                    </span>
                    <StatusBadge status={item.status} />
                  </div>
                  {item.dateRange && (
                    <p class="text-xs text-[var(--color-text-muted)] mt-0.5">
                      {item.dateRange}
                    </p>
                  )}
                  {item.vendor && (
                    <p class="text-xs text-[var(--color-text-muted)] mt-0.5">
                      via {item.vendor}
                    </p>
                  )}
                </div>
                <div class="text-right whitespace-nowrap">
                  {item.convertedCost && item.originalCost.currency !== item.convertedCost.currency && (
                    <>
                      <span class="block text-sm text-[var(--color-text-primary)]">
                        {formatCurrencySmart(item.convertedCost.amount, item.convertedCost.currency)}
                      </span>
                      <span class="block text-xs text-[var(--color-text-muted)]">
                        {formatCurrencySmart(item.originalCost.amount, item.originalCost.currency)}
                      </span>
                      <span class="block text-xs text-[var(--color-text-muted)]/60">
                        1 {item.convertedCost.currency} = {(1 / item.convertedCost.rate).toFixed(4)} {item.originalCost.currency}
                      </span>
                    </>
                  )}
                  {!item.convertedCost && (
                    <span class="text-sm font-medium text-[var(--color-text-primary)]">
                      {formatCurrencySmart(item.originalCost.amount, item.originalCost.currency)}
                    </span>
                  )}
                </div>
              </div>
            ))}
          </div>

          {/* Category subtotal footer */}
          <div class="flex items-center justify-between px-4 py-2 bg-[var(--color-bg-subtle)] border-t border-[var(--color-border)]">
            <span class="text-xs font-medium text-[var(--color-text-secondary)]">
              {category.name === 'lodging' ? 'Lodging Subtotal'
                : category.name === 'travel' ? 'Travel Subtotal'
                : category.name === 'rental-cars' ? 'Rental Cars Subtotal'
                : category.name === 'activities' ? 'Activities Subtotal'
                : category.name === 'dining' ? 'Dining Subtotal'
                : category.name === 'transfers' ? 'Transfers Subtotal'
                : 'Subtotal'}
            </span>
            <div class="text-right">
              {category.convertedSubtotal && category.originalSubtotal.currency !== category.convertedSubtotal.currency && (
                <span class="block text-xs text-[var(--color-text-muted)]">
                  {formatCurrencySmart(category.originalSubtotal.amount, category.originalSubtotal.currency)}
                </span>
              )}
              <span class="text-sm font-semibold text-[var(--color-text-primary)]">
                {formatCurrencySmart(category.convertedSubtotal?.amount ?? category.originalSubtotal.amount, 'USD')}
              </span>
            </div>
          </div>
        </section>
      )
    ))}

    {/* Grand Total */}
    <div class="sticky bottom-0 bg-[var(--color-bg-primary)] border-t border-[var(--color-border)] -mx-4 px-4 py-4 sm:-mx-6 sm:px-6">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-base font-semibold text-[var(--color-text-primary)]">Grand Total</h3>
          <p class="text-xs text-[var(--color-text-muted)]">
            {categories.reduce((sum, c) => sum + c.items.length, 0)} items across {categories.filter(c => c.items.length > 0).length} categories
            {hasMultipleCurrencies && (
              <span> · {allCurrencies.join(', ')} converted to USD</span>
            )}
          </p>
        </div>
        <div class="text-right">
          {hasMultipleCurrencies && grandTotalOriginal.currency !== 'USD' && (
            <span class="block text-sm text-[var(--color-text-secondary)]">
              {formatCurrencySmart(grandTotalOriginal.amount, grandTotalOriginal.currency)}
            </span>
          )}
          <span class="text-xl font-bold text-[var(--color-text-primary)]">
            {formatCurrencySmart(grandTotalConverted.amount, 'USD')}
          </span>
        </div>
      </div>
    </div>

    {/* Disclaimer */}
    <div class="text-xs text-[var(--color-text-muted)] text-center pt-2">
      <p>Exchange rates are estimates based on current market rates sourced from Frankfurter (ECB reference rates) and Fawaz Ahmed's Exchange API.</p>
      <p class="mt-0.5">Actual charges may vary based on your payment provider's rates, fees, and the date of transaction. Rates shown: {new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}.</p>
    </div>
  </div>
)}
