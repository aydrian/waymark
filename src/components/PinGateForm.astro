---
interface Props { tripId: string; error?: string }
const { tripId, error } = Astro.props;
---
<div class="min-h-screen flex items-center justify-center bg-[var(--color-bg)] px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-[var(--color-text-primary)]">Enter PIN</h1>
      <p class="text-sm text-[var(--color-text-secondary)] mt-2">This itinerary is PIN-protected.</p>
    </div>
    {error && (
      <div class="mb-4 rounded-lg bg-[var(--color-error-bg)] border border-[var(--color-error-border)] px-4 py-3">
        <p class="text-sm text-[var(--color-error-text)]">{error}</p>
      </div>
    )}
    <form id="pin-form" class="space-y-4">
      <div>
        <label for="pin" class="block text-sm font-medium text-[var(--color-text-primary)] mb-1">PIN</label>
        <input
          id="pin"
          name="pin"
          type="password"
          inputmode="numeric"
          autocomplete="one-time-code"
          required
          maxlength="20"
          class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2.5 text-[var(--color-text-primary)] text-center text-xl tracking-widest focus:outline-none focus:ring-2 focus:ring-[var(--color-text-primary)] focus:border-transparent"
          placeholder="••••"
        />
      </div>
      <button
        type="submit"
        class="w-full rounded-lg bg-[var(--color-btn-active-bg)] px-4 py-2.5 text-sm font-semibold text-[var(--color-btn-active-text)] hover:bg-[var(--color-btn-primary-hover)] focus:outline-none focus:ring-2 focus:ring-[var(--color-text-primary)] focus:ring-offset-2 transition-colors"
      >
        Unlock Itinerary
      </button>
    </form>
  </div>
</div>

<script define:vars={{ tripId }}>
  document.getElementById('pin-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const pin = document.getElementById('pin').value;
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Checking…';
    try {
      const res = await fetch('/api/trip-access/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: tripId, pin }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        btn.disabled = false;
        btn.textContent = 'Unlock Itinerary';
        const errEl = document.querySelector('[data-error]') ?? (() => {
          const d = document.createElement('p');
          d.setAttribute('data-error', '');
          d.setAttribute('role', 'alert');
          d.className = 'text-sm text-red-600 text-center';
          document.getElementById('pin-form').prepend(d);
          return d;
        })();
        errEl.textContent = 'Incorrect PIN. Please try again.';
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Unlock Itinerary';
      const errEl = document.querySelector('[data-error]') ?? (() => {
        const d = document.createElement('p');
        d.setAttribute('data-error', '');
        d.setAttribute('role', 'alert');
        d.className = 'text-sm text-red-600 text-center';
        document.getElementById('pin-form').prepend(d);
        return d;
      })();
      errEl.textContent = 'Something went wrong. Please try again.';
    }
  });
</script>
