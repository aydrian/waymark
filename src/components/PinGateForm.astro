---
interface Props { tripId: string; error?: string }
const { tripId, error } = Astro.props;
---
<div class="min-h-screen flex items-center justify-center bg-stone-50 px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-stone-900">Enter PIN</h1>
      <p class="text-sm text-stone-500 mt-2">This itinerary is PIN-protected.</p>
    </div>
    {error && (
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3">
        <p class="text-sm text-red-700">{error}</p>
      </div>
    )}
    <form id="pin-form" class="space-y-4">
      <div>
        <label for="pin" class="block text-sm font-medium text-stone-700 mb-1">PIN</label>
        <input
          id="pin"
          name="pin"
          type="password"
          inputmode="numeric"
          autocomplete="one-time-code"
          required
          maxlength="20"
          class="w-full rounded-lg border border-stone-300 bg-white px-4 py-2.5 text-stone-900 text-center text-xl tracking-widest focus:outline-none focus:ring-2 focus:ring-stone-900 focus:border-transparent"
          placeholder="••••"
        />
      </div>
      <button
        type="submit"
        class="w-full rounded-lg bg-stone-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-stone-700 focus:outline-none focus:ring-2 focus:ring-stone-900 focus:ring-offset-2 transition-colors"
      >
        Unlock Itinerary
      </button>
    </form>
  </div>
</div>

<script define:vars={{ tripId }}>
  document.getElementById('pin-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const pin = document.getElementById('pin').value;
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Checking…';
    try {
      const res = await fetch('/api/trip-access/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: tripId, pin }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        btn.disabled = false;
        btn.textContent = 'Unlock Itinerary';
        const errEl = document.querySelector('[data-error]') ?? (() => {
          const d = document.createElement('p');
          d.setAttribute('data-error', '');
          d.className = 'text-sm text-red-600 text-center';
          document.getElementById('pin-form').prepend(d);
          return d;
        })();
        errEl.textContent = 'Incorrect PIN. Please try again.';
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Unlock Itinerary';
    }
  });
</script>
