---
import type { TripItem } from '../types/itinerary';
import StatusBadge from './StatusBadge.astro';
interface Props { item: TripItem }
const { item } = Astro.props;

const icons: Record<string, string> = {
  hotel: '🏨', transport: '✈️', activity: '🎯',
  note: '📝', restaurant: '🍽️', transfer: '🚗',
};

const mapsUrl = (() => {
  if (item.lat != null && item.lng != null) return `https://maps.google.com/?q=${item.lat},${item.lng}`;
  if (item.address) return `https://maps.google.com/maps/search/?q=${encodeURIComponent(item.address)}`;
  if (item.location) return `https://maps.google.com/maps/search/?q=${encodeURIComponent(item.location)}`;
  return undefined;
})();
---
<article class="flex gap-3 py-3">
  <div aria-hidden="true" class="flex-shrink-0 w-8 h-8 rounded-full bg-[var(--color-bg-subtle)] flex items-center justify-center text-base">
    {icons[item.type] ?? '📌'}
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-start gap-2 flex-wrap">
      <h3 class="text-sm font-semibold text-[var(--color-text-primary)] leading-snug">{item.title}</h3>
      <StatusBadge status={item.status} />
    </div>
    {(item.startTime || item.endTime) && (
      <p class="text-xs text-[var(--color-text-secondary)] mt-0.5">
        {item.startTime}{item.endTime ? ` – ${item.endTime}` : ''}
      </p>
    )}
    {item.location && (
      <p class="text-xs text-[var(--color-text-secondary)] mt-0.5">
        {item.location}
        {mapsUrl && (
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="ml-1 inline-flex items-center text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)]" aria-label={`Open ${item.location} in Google Maps`}>📍</a>
        )}
      </p>
    )}
    {item.address && (
      <p class="text-xs text-[var(--color-text-muted)] mt-0.5">
        {mapsUrl
          ? <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="underline decoration-dotted hover:text-[var(--color-text-secondary)]">{item.address}</a>
          : item.address
        }
      </p>
    )}
    {item.vendor && (
      <p class="text-xs text-[var(--color-text-muted)] mt-0.5">via {item.vendor}</p>
    )}
    {item.confirmationNumber && (
      <p class="text-xs text-[var(--color-text-muted)] mt-0.5 font-mono">Conf: {item.confirmationNumber}</p>
    )}
    {item.notes && (
      <p class="text-xs text-[var(--color-text-secondary)] mt-1 whitespace-pre-wrap">{item.notes}</p>
    )}
  </div>
</article>
