---
import type { TripItem } from '../types/itinerary';
import StatusBadge from './StatusBadge.astro';
interface Props { item: TripItem }
const { item } = Astro.props;

const icons: Record<string, string> = {
  hotel: '🏨', transport: '✈️', activity: '🎯',
  note: '📝', restaurant: '🍽️', transfer: '🚗',
};
---
<article class="flex gap-3 py-3">
  <div aria-hidden="true" class="flex-shrink-0 w-8 h-8 rounded-full bg-stone-100 flex items-center justify-center text-base">
    {icons[item.type] ?? '📌'}
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-start gap-2 flex-wrap">
      <h3 class="text-sm font-semibold text-stone-900 leading-snug">{item.title}</h3>
      <StatusBadge status={item.status} />
    </div>
    {(item.startTime || item.endTime) && (
      <p class="text-xs text-stone-500 mt-0.5">
        {item.startTime}{item.endTime ? ` – ${item.endTime}` : ''}
      </p>
    )}
    {item.location && (
      <p class="text-xs text-stone-500 mt-0.5">{item.location}</p>
    )}
    {item.vendor && (
      <p class="text-xs text-stone-400 mt-0.5">via {item.vendor}</p>
    )}
    {item.confirmationNumber && (
      <p class="text-xs text-stone-400 mt-0.5 font-mono">Conf: {item.confirmationNumber}</p>
    )}
    {item.notes && (
      <p class="text-xs text-stone-600 mt-1 whitespace-pre-wrap">{item.notes}</p>
    )}
  </div>
</article>
