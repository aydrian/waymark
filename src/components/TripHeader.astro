---
import type { Itinerary } from '../types/itinerary';
interface Props { trip: Itinerary }
const { trip } = Astro.props;

const fmt = (d: string) => new Date(d + 'T00:00:00').toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
---
<header class="bg-white border-b border-stone-200 px-4 py-6 sm:px-6">
  <p class="text-xs font-semibold uppercase tracking-widest text-stone-400 mb-1">
    {trip.destinations.join(' · ')}
  </p>
  <h1 class="text-2xl font-bold text-stone-900 sm:text-3xl">{trip.title}</h1>
  <p class="mt-1 text-sm text-stone-500">{fmt(trip.startDate)} – {fmt(trip.endDate)}</p>
  {trip.summary && (
    <p class="mt-3 text-sm text-stone-600 max-w-prose leading-relaxed">{trip.summary}</p>
  )}
  {trip.notes && (
    <div class="mt-3 rounded-lg bg-amber-50 border border-amber-200 px-4 py-3">
      <p class="text-xs font-semibold text-amber-700 uppercase tracking-wide mb-1">Notes</p>
      <p class="text-sm text-amber-900 whitespace-pre-wrap">{trip.notes}</p>
    </div>
  )}
</header>
