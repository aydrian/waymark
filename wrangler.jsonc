{
  "name": "waymark",
  "compatibility_date": "2026-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/server/entry.mjs",
  "assets": {
    "directory": "./dist/client"
  },
  "kv_namespaces": [
    {
      "binding": "TRIPS",
      "id": "REPLACE_WITH_KV_ID",
      "preview_id": "REPLACE_WITH_PREVIEW_KV_ID"
    }
  ]
}
